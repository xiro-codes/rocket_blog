<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="utf-8" />
		<!--link rel="stylesheet" href="/static/reset.css" /-->
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<!-- Local Bootstrap CSS (fallback for CDN) -->
		<link rel="stylesheet" href="/static/libs/bootstrap-minimal.css">
		<!-- Local Fonts CSS (fallback for Google Fonts) -->
		<link rel="stylesheet" href="/static/libs/fonts-fallback.css">
		<!-- EasyMDE Terminal Theme CSS (fallback for CDN) -->
		<link rel="stylesheet" href="/static/libs/easymde-terminal.css">
		<!-- Main application styles -->
		<link rel="stylesheet" href="/static/style.css" />
		<link rel="alternate" type="application/rss+xml" title="Rocket Blog RSS Feed" href="/feed/rss" />
		<style>
body {
	background-color: #0c1116;
	width: 100vw;
	height: 100vh;
	font-family: 'JetBrains Mono', 'Source Code Pro', 'Courier New', monospace;
	color: #00ff41;
}

/* EasyMDE Terminal Theme Customization */
.EasyMDEContainer {
	border: 2px solid #333 !important;
	background-color: #1a1f25 !important;
}

.EasyMDEContainer .editor-toolbar {
	background-color: #0c1116 !important;
	border-bottom: 1px solid #333 !important;
	border-top: none !important;
	border-left: none !important;
	border-right: none !important;
}

.EasyMDEContainer .editor-toolbar button {
	color: #00ff41 !important;
	background-color: transparent !important;
	border: none !important;
	border-radius: 0 !important;
	font-family: 'JetBrains Mono', 'Source Code Pro', 'Courier New', monospace !important;
}

.EasyMDEContainer .editor-toolbar button:hover {
	background-color: #333 !important;
	color: #40ff80 !important;
}

.EasyMDEContainer .editor-toolbar button.active {
	background-color: #00ff41 !important;
	color: #0c1116 !important;
}

.EasyMDEContainer .CodeMirror {
	background-color: #1a1f25 !important;
	color: #00ff41 !important;
	font-family: 'JetBrains Mono', 'Source Code Pro', 'Courier New', monospace !important;
	border: none !important;
	line-height: 1.5 !important;
}

.EasyMDEContainer .CodeMirror-cursor {
	border-left: 1px solid #00ff41 !important;
}

.EasyMDEContainer .CodeMirror-selected {
	background-color: #333 !important;
}

.EasyMDEContainer .CodeMirror-line {
	color: #00ff41 !important;
}

.EasyMDEContainer .cm-header {
	color: #40ff80 !important;
	font-weight: bold !important;
}

.EasyMDEContainer .cm-quote {
	color: #888 !important;
	font-style: italic !important;
}

.EasyMDEContainer .cm-keyword {
	color: #00ff41 !important;
	font-weight: bold !important;
}

.EasyMDEContainer .cm-link {
	color: #40ff80 !important;
}

.EasyMDEContainer .cm-url {
	color: #40ff80 !important;
}

.EasyMDEContainer .editor-statusbar {
	background-color: #0c1116 !important;
	color: #888 !important;
	border-top: 1px solid #333 !important;
	border-bottom: none !important;
	border-left: none !important;
	border-right: none !important;
	font-family: 'JetBrains Mono', 'Source Code Pro', 'Courier New', monospace !important;
}

.EasyMDEContainer .editor-preview, .EasyMDEContainer .editor-preview-active-side {
	background-color: #1a1f25 !important;
	color: #ccc !important;
	font-family: 'JetBrains Mono', 'Source Code Pro', 'Courier New', monospace !important;
}

.EasyMDEContainer .editor-preview h1, 
.EasyMDEContainer .editor-preview h2, 
.EasyMDEContainer .editor-preview h3, 
.EasyMDEContainer .editor-preview h4, 
.EasyMDEContainer .editor-preview h5, 
.EasyMDEContainer .editor-preview h6 {
	color: #00ff41 !important;
	font-weight: 700 !important;
}

.EasyMDEContainer .editor-preview code {
	background-color: #0c1116 !important;
	color: #00ff41 !important;
	border: 1px solid #333 !important;
}

.EasyMDEContainer .editor-preview pre {
	background-color: #0c1116 !important;
	border: 1px solid #333 !important;
}
		</style>
	</head>

	<body>
		<div class="container-fluid terminal-container h-100">
			{% block content %}
			{% endblock %}
		</div>
		<!-- Local JavaScript fallbacks -->
		<script src="/static/libs/easymde-fallback.js"></script>
		<script>
			// Bootstrap popover fallback (basic implementation)
			if (typeof bootstrap !== 'undefined' && bootstrap.Popover) {
				const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]')
				const popoverList = [...popoverTriggerList].map(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl))
			}
		</script>
		{% block script %}
		{% endblock %}
	</body>

</html>
