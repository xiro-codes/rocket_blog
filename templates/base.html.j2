<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="utf-8" />
		<!--link rel="stylesheet" href="/static/reset.css" /-->
		<meta name="viewport" content="width=device-width, initial-scale=1">
		
		<!-- SEO Meta Tags -->
		<title>{% if page_title %}{{ page_title }}{% else %}Rocket Blog - A Modern Blog Platform{% endif %}</title>
		<meta name="description" content="{% if page_description %}{{ page_description }}{% else %}A modern blog platform built with Rust and Rocket framework. Discover insightful articles, technical content, and more.{% endif %}">
		<meta name="keywords" content="{% if page_keywords %}{{ page_keywords }}{% else %}blog, rust, rocket, programming, technology, articles{% endif %}">
		<meta name="author" content="Rocket Blog">
		
		<!-- Canonical URL -->
		<link rel="canonical" href="{% if canonical_url %}{{ canonical_url }}{% else %}/{% endif %}">
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content="{% if page_title %}{{ page_title }}{% else %}Rocket Blog{% endif %}">
		<meta property="og:description" content="{% if page_description %}{{ page_description }}{% else %}A modern blog platform built with Rust and Rocket framework{% endif %}">
		<meta property="og:type" content="{% if post %}article{% else %}website{% endif %}">
		<meta property="og:url" content="{% if canonical_url %}{{ canonical_url }}{% else %}/{% endif %}">
		<meta property="og:site_name" content="Rocket Blog">
		<meta property="og:locale" content="en_US">
		{% if post %}
		<meta property="article:published_time" content="{{ post.date_published }}">
		{% if tags %}
		{% for tag in tags %}
		<meta property="article:tag" content="{{ tag.name }}">
		{% endfor %}
		{% endif %}
		{% endif %}
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary">
		<meta name="twitter:title" content="{% if page_title %}{{ page_title }}{% else %}Rocket Blog{% endif %}">
		<meta name="twitter:description" content="{% if page_description %}{{ page_description }}{% else %}A modern blog platform built with Rust and Rocket framework{% endif %}">
		
		<!-- RSS Feed -->
		<link rel="alternate" type="application/rss+xml" title="Rocket Blog RSS Feed" href="/feed/rss" />
		
		<!-- PWA Manifest -->
		<link rel="manifest" href="/static/manifest.json">
		
		<!-- PWA Meta Tags -->
		<meta name="mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="apple-mobile-web-app-title" content="TimeTracker">
		<meta name="msapplication-TileColor" content="#0c1116">
		<meta name="msapplication-tap-highlight" content="no">
		
		<!-- PWA Icons -->
		<link rel="apple-touch-icon" href="/static/icon-192x192.png">
		<link rel="icon" type="image/png" sizes="192x192" href="/static/icon-192x192.png">
		<link rel="icon" type="image/png" sizes="512x512" href="/static/icon-512x512.png">
		
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
																							 integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="/static/style.css" />
		<!-- EasyMDE Markdown Editor -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.css">
		<style>
		/* Xe Iaso inspired styling */
		:root {
			--bg-0: #fdfdfc;
			--bg-1: #f4f4f4;
			--bg-2: #eaeaea;
			--fg-0: #1c1c1c;
			--fg-1: #3a3a3a;
			--fg-3: #6b6b6b;
			--link: #0056b3;
			--link-hover: #003d82;
			--font-sans: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
			--font-serif: "Georgia", "Times New Roman", serif;
		}

		@media (prefers-color-scheme: dark) {
			:root {
				--bg-0: #1a1a1a;
				--bg-1: #242424;
				--bg-2: #2a2a2a;
				--fg-0: #e0e0e0;
				--fg-1: #b0b0b0;
				--fg-3: #8a8a8a;
				--link: #66b3ff;
				--link-hover: #99ccff;
			}
		}

		body {
			background-color: var(--bg-0);
			color: var(--fg-0);
			font-family: var(--font-sans);
			line-height: 1.6;
			margin: 0;
			padding: 0;
		}

		a {
			color: var(--link);
			text-decoration: underline;
		}
		a:hover {
			color: var(--link-hover);
			text-decoration: none;
		}

		h1, h2, h3, h4, h5, h6 {
			font-family: var(--font-serif);
			color: var(--fg-0);
			margin-bottom: 1rem;
		}

		.container-fluid {
			max-width: 800px;
			margin: 0 auto;
			padding: 1rem;
		}

		.card {
			background-color: var(--bg-1);
			border: 1px solid var(--bg-2);
			border-radius: 6px;
			box-shadow: none;
			margin-bottom: 1.5rem;
		}

		.card-body {
			padding: 1.5rem;
		}

		.btn, .btn-primary, .btn-success, .btn-secondary, .btn-info, .btn-warning {
			background-color: var(--bg-2);
			color: var(--fg-0);
			border: 1px solid var(--bg-2);
			border-radius: 4px;
			padding: 0.5rem 1rem;
			text-transform: none;
			font-family: var(--font-sans);
			text-decoration: none;
			display: inline-block;
			transition: background-color 0.2s;
		}

		.btn:hover, .btn-primary:hover, .btn-success:hover, .btn-secondary:hover {
			background-color: var(--bg-0);
			color: var(--fg-0);
			border-color: var(--fg-1);
		}

		/* EasyMDE Theme Fixes for Xe style */
		.EasyMDEContainer .editor-toolbar, .EasyMDEContainer .CodeMirror, .EasyMDEContainer .editor-statusbar {
			background-color: var(--bg-1) !important;
			color: var(--fg-0) !important;
			border-color: var(--bg-2) !important;
		}
		.EasyMDEContainer .editor-toolbar button { color: var(--fg-0) !important; }
		.EasyMDEContainer .editor-toolbar button.active, .EasyMDEContainer .editor-toolbar button:hover {
			background-color: var(--bg-2) !important;
		}
		.EasyMDEContainer .CodeMirror-cursor { border-left: 1px solid var(--fg-0) !important; }
		.EasyMDEContainer .CodeMirror-line { color: var(--fg-0) !important; }


		
		.list-group-item {
			background-color: var(--bg-0);
			border-color: var(--bg-2);
			color: var(--fg-0);
		}
		
		.text-muted {
			color: var(--fg-3) !important;
		}
		</style>
	</head>

	<body>
		<div class="container-fluid h-100">
			{% block content %}
			{% endblock %}
		</div>
		<script>
			const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]')
			const popoverList = [...popoverTriggerList].map(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl))
		</script>
		{% block script %}
		{% endblock %}
		<script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
				integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
				crossorigin="anonymous"></script>
		<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
				integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
				crossorigin="anonymous"></script>
		<!-- EasyMDE Markdown Editor -->
		<script src="https://cdn.jsdelivr.net/npm/easymde@2.18.0/dist/easymde.min.js"></script>
		
		<!-- PWA Service Worker Registration -->
		<script>
			// Register service worker for PWA functionality
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/static/sw.js')
						.then((registration) => {
							console.log('SW registered: ', registration);
							
							// Check for updates
							registration.addEventListener('updatefound', () => {
								const newWorker = registration.installing;
								newWorker.addEventListener('statechange', () => {
									if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
										// New update available
										console.log('New version available! Please refresh.');
									}
								});
							});
						})
						.catch((registrationError) => {
							console.log('SW registration failed: ', registrationError);
						});
				});
			}

			// PWA Install prompt
			let deferredPrompt;
			window.addEventListener('beforeinstallprompt', (e) => {
				e.preventDefault();
				deferredPrompt = e;
				
				// Show install button/banner if needed
				console.log('PWA install prompt available');
			});

			// Handle PWA installation
			function installPWA() {
				if (deferredPrompt) {
					deferredPrompt.prompt();
					deferredPrompt.userChoice.then((choiceResult) => {
						if (choiceResult.outcome === 'accepted') {
							console.log('User accepted the install prompt');
						}
						deferredPrompt = null;
					});
				}
			}
		</script>
	</body>

</html>
