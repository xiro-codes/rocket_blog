{% extends "worktime_base" %}

{% block content %}
<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex justify-center text-blue-600 mb-6">
            <i class="fas fa-user-plus" style="font-size: 3.5rem;"></i>
        </div>
        
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 dark:text-white">Join Time Tracker</h2>
        <p class="mt-2 text-center text-sm text-gray-600 dark:text-gray-400 max-w">
            Create your account to start tracking your productive work hours and boost your productivity.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white dark:bg-gray-800 py-8 px-4 shadow sm:rounded-lg sm:px-10 border border-gray-200 dark:border-gray-700">
            <form action="/auth/register" method="post" class="space-y-6">
                <div>
                    <label for="username" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                        <i class="fas fa-user mr-1 text-gray-400"></i>Username
                    </label>
                    <div class="mt-1">
                        <input id="username" name="username" type="text" required class="appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-900 text-gray-900 dark:text-white transition" placeholder="Choose a unique username">
                    </div>
                    <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">This will be your login identifier</p>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 dark:text-gray-300">
                        <i class="fas fa-lock mr-1 text-gray-400"></i>Password
                    </label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" required class="appearance-none block w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-900 text-gray-900 dark:text-white transition" placeholder="Create a secure password">
                    </div>
                    <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Choose a strong password for security</p>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition">
                        <i class="fas fa-user-plus mr-2 mt-0.5"></i>Create Account
                    </button>
                </div>
            </form>

            <div class="mt-6 space-y-3">
                <a href="/auth" class="w-full flex justify-center py-2.5 px-4 border border-blue-600 rounded-md shadow-sm text-sm font-medium text-blue-600 bg-white dark:bg-gray-800 hover:bg-blue-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition">
                    <i class="fas fa-sign-in-alt mr-2 mt-0.5"></i>Already have an account?
                </a>
                <a href="/blog" class="w-full flex justify-center py-2.5 px-4 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition">
                    <i class="fas fa-arrow-left mr-2 mt-0.5"></i>Back to Blog
                </a>
            </div>
        </div>

        <!-- Features highlight -->
        <div class="mt-8">
            <h3 class="text-center text-sm font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wide">What you'll get</h3>
            <div class="mt-5 grid grid-cols-2 gap-4 text-sm text-gray-600 dark:text-gray-400">
                <div class="flex items-center">
                    <i class="fas fa-stopwatch text-blue-500 mr-2"></i><span>Precise time tracking</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-users text-emerald-500 mr-2"></i><span>Multiple work roles</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-calendar text-amber-500 mr-2"></i><span>Pay period management</span>
                </div>
                <div class="flex items-center">
                    <i class="fas fa-mobile-alt text-cyan-500 mr-2"></i><span>Mobile-friendly PWA</span>
                </div>
            </div>
        </div>
        
        {% if flash %}
        <div class="mt-8 rounded-md bg-{{ 'green' if flash[0] == 'success' else 'red' }}-50 p-4 border border-{{ 'green' if flash[0] == 'success' else 'red' }}-200">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i class="fas fa-info-circle text-{{ 'green' if flash[0] == 'success' else 'red' }}-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium text-{{ 'green' if flash[0] == 'success' else 'red' }}-800">
                        {{ flash[1] }}
                    </p>
                </div>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}