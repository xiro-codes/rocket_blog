{% extends "base" %}

{% block content %}
<div></div>
<center>
	<h1>Create Admin Account</h1>
	<p class="text-muted">No admin account exists. Create the first admin account to manage the blog.</p>
</center>

<hr>

<div class="d-flex justify-content-center align-items-center">
	<form action="/auth/create-admin" method="post">
		<h3 class="text-center mb-4">Admin Account Setup</h3>
		
		<div>
			<label for="username" class="form-label">Username:</label>
			<input type="text" name="username" id="username" class="form-control" placeholder="Enter admin username..." required />
		</div>
		
		<div>
			<label for="email" class="form-label">Email:</label>
			<input type="email" name="email" id="email" class="form-control" placeholder="Enter admin email..." required />
		</div>
		
		<div>
			<label for="password" class="form-label">Password:</label>
			<input type="password" name="password" id="password" class="form-control" placeholder="Enter secure password..." required />
		</div>
		
		<div class="justify-content-center d-flex m-1">
			<button type="submit" class="btn btn-primary">Create Admin Account</button>
		</div>
		
		<div class="text-center mt-3">
			<a href="/blog" class="btn btn-secondary btn-sm">Back to Blog</a>
		</div>
	</form>
</div>

{% if flash %}
<div class="alert alert-{{ flash[0] }} text-center mt-3">
	{{ flash[1] }}
</div>
{% endif %}

{% endblock %}