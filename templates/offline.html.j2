{% extends "base" %}

{% block content %}
<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center">
                <h1>🔌 Offline</h1>
                <p class="lead">You're currently offline, but don't worry!</p>
                
                <div class="alert alert-info">
                    <h4>📱 PWA Offline Features</h4>
                    <p>This application works offline. You can:</p>
                    <ul class="list-unstyled">
                        <li>✅ View cached content</li>
                        <li>✅ Access previously loaded data</li>
                        <li>✅ Browse offline pages</li>
                        <li>✅ Create content (syncs when online)</li>
                    </ul>
                </div>

                <div class="mt-4">
                    <h5>🔄 When you're back online:</h5>
                    <ul class="text-start">
                        <li>All offline changes will sync automatically</li>
                        <li>Your data will be saved to the server</li>
                        <li>Fresh content will be loaded</li>
                    </ul>
                </div>

                <div class="mt-4 flex justify-center gap-4">
                    <button onclick="window.location.reload()" class="glow-btn px-6 py-3 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-bold transition-all shadow-[0_0_15px_rgba(0,168,244,0.3)] flex items-center gap-2">
                        <i class="fas fa-sync-alt"></i> Check Connection
                    </button>
                    <a href="/worktime/" class="px-6 py-3 rounded-full bg-green-500/20 hover:bg-green-500/30 border border-green-500/50 text-green-400 font-bold transition-all flex items-center gap-2">
                        <i class="fas fa-chart-pie"></i> View Cached App
                    </a>
                </div>

                <div class="mt-4 text-muted">
                    <small>
                        💡 Tip: Add this app to your home screen for the best offline experience!
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Auto-reload when connection is restored
window.addEventListener('online', () => {
    console.log('Connection restored, reloading...');
    window.location.reload();
});

// Show current connection status
function updateConnectionStatus() {
    const status = navigator.onLine ? 'Online' : 'Offline';
    console.log('Connection status:', status);
}

window.addEventListener('online', updateConnectionStatus);
window.addEventListener('offline', updateConnectionStatus);
updateConnectionStatus();
</script>
{% endblock %}