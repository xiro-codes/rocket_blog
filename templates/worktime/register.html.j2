{% extends "worktime_base" %}

{% block content %}
<div class="flex flex-col min-h-screen bg-gray-50 dark:bg-gray-900">
	<div class="flex-1 w-full max-w-5xl mx-auto p-4 sm:p-6 lg:p-8">
		<div class="text-center mb-4">
			<h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">🚀 Create Account</h1>
			<p class="mt-2 text-lg text-gray-600 dark:text-gray-400">Create an account to start tracking your work time and manage your earnings.</p>
		</div>

		<div class="row justify-content-center">
			<div class="col-md-6 col-lg-4">
				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 font-semibold">
						<h3 class="text-center mb-0">Register for TimeTracker</h3>
					</div>
					<form action="/worklog/register" method="post">
						<div class="mb-3">
							<label for="username" class="form-label">Username</label>
							<input type="text" name="username" id="username" class="form-control" placeholder="Choose a username..." required />
						</div>
						
						<div class="mb-3">
							<label for="password" class="form-label">Password</label>
							<input type="password" name="password" id="password" class="form-control" placeholder="Create a password..." required />
						</div>
						
						<div class="d-grid mb-3">
							<button type="submit" class="btn btn-primary">Create Account</button>
						</div>
						
						<div class="text-center">
							<a href="/worklog/" class="btn btn-secondary btn-sm">← Back to Login</a>
						</div>
					</form>
				</div>
			</div>
		</div>

		{% if flash %}
		<div class="row justify-content-center">
			<div class="col-md-6 col-lg-4">
				<div class="alert alert-{{ flash[0] }} text-center">
					{{ flash[1] }}
				</div>
			</div>
		</div>
		{% endif %}

		<div class="row justify-content-center mt-4">
			<div class="col-md-8 col-lg-6">
				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
					<h4 class="text-center mb-3">🎯 Get Started with Work Time Tracking</h4>
					<p class="text-center mb-3"><strong>After registration, you'll be able to:</strong></p>
					<div class="row">
						<div class="col-md-6">
							<ul class="list-unstyled">
								<li class="mb-2">⚙️ Set up roles with different hourly rates</li>
								<li class="mb-2">⏱️ Track work sessions with start/stop timer</li>
								<li class="mb-2">📋 Organize work into configurable pay periods</li>
							</ul>
						</div>
						<div class="col-md-6">
							<ul class="list-unstyled">
								<li class="mb-2">🎯 Set up notifications and daily goals</li>
								<li class="mb-2">💰 View detailed earnings and time reports</li>
								<li class="mb-2">📱 Access everything offline via PWA</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% endblock %}