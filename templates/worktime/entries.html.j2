{% extends "worktime_base" %}
{% import "worktime_macros" as wt %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="worktime-title mb-0">
        <i class="fas fa-list-ul me-2"></i>Work Time Entries
    </h1>
    <a href="/" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

{{ wt.quick_nav(current_page="entries", show_mobile_menu=false) }}

<!-- Summary Stats -->
<div class="stats-grid">
    <div class="stat-card">
        <span class="stat-value">{{ total_entries }}</span>
        <span class="stat-label">
            <i class="fas fa-briefcase me-1"></i>Total Entries
        </span>
    </div>
    <div class="stat-card">
        <span class="stat-value">{{ total_hours | round(1) }}h</span>
        <span class="stat-label">
            <i class="fas fa-clock me-1"></i>Total Hours
        </span>
    </div>
    <div class="stat-card">
        <span class="stat-value">${{ total_earnings | round(2) }}</span>
        <span class="stat-label">
            <i class="fas fa-dollar-sign me-1"></i>Total Earnings
        </span>
    </div>
</div>

<!-- Entries Table -->
{% call wt.worktime_card(title="All Entries", icon="fas fa-history") %}
    {% if entries %}
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Role</th>
                        <th>Duration</th>
                        <th class="d-none d-md-table-cell">Time</th>
                        <th>Earnings</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in entries %}
                    <tr>
                        <td>{{ entry.start_time_display | split(" ") | first }}</td>
                        <td>
                            <span class="badge" style="background-color: var(--primary); color: var(--text-white);">
                                {{ entry.role_name }}
                            </span>
                        </td>
                        <td>
                            {% if entry.duration and not entry.is_active %}
                                <strong>{{ wt.format_duration(entry.duration) }}</strong>
                            {% elif entry.is_active %}
                                <span class="status-badge status-active">
                                    <i class="fas fa-circle"></i>Active
                                </span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="d-none d-md-table-cell text-muted">
                            {{ entry.start_time_display | split(" ") | last }}
                        </td>
                        <td>
                            {% if entry.earnings %}
                                <strong class="text-success">{{ wt.format_currency(entry.earnings) }}</strong>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if entry.end_time and not entry.is_active %}
                                <span class="status-badge" style="background-color: var(--success); color: var(--text-primary);">
                                    <i class="fas fa-check"></i>Complete
                                </span>
                            {% elif entry.is_active %}
                                <span class="status-badge status-active">
                                    <i class="fas fa-play"></i>Running
                                </span>
                            {% else %}
                                <span class="status-badge" style="background-color: var(--warning); color: var(--text-primary);">
                                    <i class="fas fa-clock"></i>Pending
                                </span>
                            {% endif %}
                        </td>
                        <td>
                            {% if not entry.is_active %}
                                <a href="/entries/{{ entry.id }}/edit" class="btn btn-sm btn-outline-primary" title="Edit Entry">
                                    <i class="fas fa-edit"></i>
                                </a>
                                {% if entry.can_add_tips %}
                                    <a href="/entries/{{ entry.id }}/tips" class="btn btn-sm btn-outline-success" title="Add Tips">
                                        <i class="fas fa-coins"></i>
                                    </a>
                                {% endif %}
                            {% else %}
                                <form method="post" action="/stop" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-danger" title="Stop Timer">
                                        <i class="fas fa-stop"></i>
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="text-center">
            <i class="fas fa-list text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="text-muted mt-3">No entries found. Start tracking your work time!</p>
            <a href="/" class="btn btn-primary">
                <i class="fas fa-play me-2"></i>Start Timer
            </a>
        </div>
    {% endif %}
{% endcall %}
{% if flash %}
<div class="alert alert-{{ flash[0] }} mt-3">
    <i class="fas fa-info-circle me-2"></i>{{ flash[1] }}
</div>
{% endif %}

<!-- Add Manual Entry Form -->
{% call wt.worktime_card(title="Add Manual Entry", icon="fas fa-plus") %}
    <p class="text-muted mb-4">Add a work session that wasn't tracked with the timer.</p>
    
    <form method="post" action="/entries" class="row g-3">
        <div class="col-md-6">
            <label for="user_role_id" class="form-label">
                <i class="fas fa-user-tag me-1"></i>Role
            </label>
            <select class="form-control" id="user_role_id" name="user_role_id" required>
                <option value="">Select a role...</option>
                {% for role in roles %}
                    <option value="{{ role.id }}">{{ role.role_name }} (${{ role.hourly_wage }}/hr)</option>
                {% endfor %}
            </select>
        </div>
        
        <div class="col-md-6">
            <label for="start_time" class="form-label">
                <i class="fas fa-play me-1"></i>Start Time
            </label>
            <input type="datetime-local" class="form-control" id="start_time" name="start_time" required>
        </div>
        <div class="col-md-6">
            <label for="end_time" class="form-label">
                <i class="fas fa-stop me-1"></i>End Time
            </label>
            <input type="datetime-local" class="form-control" id="end_time" name="end_time" required>
        </div>
        <div class="col-12 text-center">
            <button type="submit" class="btn btn-success btn-lg">
                <i class="fas fa-save me-2"></i>Add Entry
            </button>
        </div>
    </form>
{% endcall %}

{% endblock %}

{% block script %}
<!-- Include Work Time utilities -->
<script src="/static/worktime-utils.js"></script>
<script>
// Auto-fill current time for start time
document.addEventListener('DOMContentLoaded', function() {
    const now = new Date();
    const startTimeInput = document.getElementById('start_time');
    if (startTimeInput && !startTimeInput.value) {
        // Set to one hour ago
        const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000);
        startTimeInput.value = oneHourAgo.toISOString().slice(0, 16);
    }
    
    const endTimeInput = document.getElementById('end_time');
    if (endTimeInput && !endTimeInput.value) {
        endTimeInput.value = now.toISOString().slice(0, 16);
    }
});
</script>
{% endblock %}
