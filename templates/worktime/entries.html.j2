{% extends "worktime_base" %}
{% import "worktime_macros" as wt %}

{% block content %}
<div class="flex justify-between items-center mb-8 animate-fade-in-up">
    <h1 class="text-3xl font-black text-white tracking-tighter">
        <i class="fas fa-list-ul me-2 text-hypr-cyan"></i>Work Time Entries
    </h1>
    <a href="/worktime/" class="px-5 py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 text-white transition-all text-sm font-medium backdrop-blur-md">
        <i class="fas fa-arrow-left me-2"></i>Dashboard
    </a>
</div>

{{ wt.quick_nav(current_page="entries", show_mobile_menu=false) }}

<!-- Summary Stats -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <div class="glass-panel border-white/10 rounded-xl p-6 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-white">{{ total_entries }}</span>
        <span class="text-xs font-mono text-hypr-cyan mt-2 text-center uppercase tracking-wider">
            <i class="fas fa-briefcase me-1"></i>Total Entries
        </span>
    </div>
    <div class="glass-panel border-white/10 rounded-xl p-6 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-white">{{ total_hours | round(1) }}h</span>
        <span class="text-xs font-mono text-hypr-cyan mt-2 text-center uppercase tracking-wider">
            <i class="fas fa-clock me-1"></i>Total Hours
        </span>
    </div>
    <div class="glass-panel border-white/10 rounded-xl p-6 flex flex-col items-center justify-center">
        <span class="text-3xl font-black text-white">${{ total_earnings | round(2) }}</span>
        <span class="text-xs font-mono text-hypr-cyan mt-2 text-center uppercase tracking-wider">
            <i class="fas fa-dollar-sign me-1"></i>Total Earnings
        </span>
    </div>
</div>

<!-- Entries Table -->
{% call wt.worktime_card(title="All Entries", icon="fas fa-history") %}
    {{ wt.entries_table(entries, show_actions=true) }}
{% endcall %}

{% if flash %}
<div class="mt-6 p-4 rounded-xl glass-panel {% if flash[0] == 'success' %}border-green-500/50 shadow-[0_0_30px_rgba(34,197,94,0.2)]{% else %}border-red-500/50 shadow-[0_0_30px_rgba(239,68,68,0.2)]{% endif %} animate-fade-in-up">
    <p class="font-mono text-sm {% if flash[0] == 'success' %}text-green-400{% else %}text-red-400{% endif %} mb-1">// SYSTEM NOTICE</p>
    <p class="text-white">{{ flash[1] }}</p>
</div>
{% endif %}

<!-- Add Manual Entry Form -->
{% call wt.worktime_card(title="Add Manual Entry", icon="fas fa-plus") %}
    <p class="text-slate-400 mb-6 text-sm">Add a work session that wasn't tracked with the timer.</p>
    
    <form method="post" action="/worktime/entries" class="space-y-6 mx-auto max-w-2xl">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-3">
                <label for="user_role_id" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-user-tag me-1 text-hypr-cyan"></i>Role
                </label>
                <select class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all" id="user_role_id" name="user_role_id" required>
                    <option value="">Select a role...</option>
                    {% for role in roles %}
                        <option value="{{ role.id }}">{{ role.role_name }} (${{ role.hourly_wage }}/hr)</option>
                    {% endfor %}
                </select>
            </div>
            
            <div class="space-y-3">
                <label for="start_time" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-play me-1 text-hypr-cyan"></i>Start Time
                </label>
                <input type="datetime-local" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all [color-scheme:dark]" id="start_time" name="start_time" required>
            </div>
            <div class="space-y-3">
                <label for="end_time" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-stop me-1 text-hypr-cyan"></i>End Time
                </label>
                <input type="datetime-local" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all [color-scheme:dark]" id="end_time" name="end_time" required>
            </div>
        </div>
        <div class="text-center pt-4 border-t border-white/10">
            <button type="submit" class="glow-btn px-10 py-4 mt-4 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-bold transition-transform hover:scale-105 shadow-[0_0_20px_rgba(0,168,244,0.3)] inline-flex items-center gap-2">
                <i class="fas fa-save text-hypr-cyan"></i> Add Entry
            </button>
        </div>
    </form>
{% endcall %}

{% endblock %}

{% block script %}
<script src="/static/worktime-utils.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const now = new Date();
    const startTimeInput = document.getElementById('start_time');
    if (startTimeInput && !startTimeInput.value) {
        const oneHourAgo = new Date(now.getTime() - 60 * 60 * 1000);
        // Correctly format datetime-local strings
        startTimeInput.value = new Date(oneHourAgo.getTime() - (oneHourAgo.getTimezoneOffset() * 60000)).toISOString().slice(0, 16);
    }
    
    const endTimeInput = document.getElementById('end_time');
    if (endTimeInput && !endTimeInput.value) {
        endTimeInput.value = new Date(now.getTime() - (now.getTimezoneOffset() * 60000)).toISOString().slice(0, 16);
    }
});
</script>
{% endblock %}