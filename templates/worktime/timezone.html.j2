{% extends "worktime_base" %}

{% block worktime_content %}
<div class="container mx-auto px-4 py-8 max-w-4xl">
    <div class="bg-white rounded-lg shadow-md p-6">
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Timezone Settings</h1>
            <a href="/worklog/" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                Back to Dashboard
            </a>
        </div>

        <div class="mb-6">
            <p class="text-gray-600 text-lg">
                Configure your preferred timezone for time display throughout the work time tracker.
                All times will be shown in your selected timezone while being stored accurately in UTC.
            </p>
        </div>

        <!-- Current Timezone Display -->
        <div class="mb-8 p-4 bg-blue-50 border-l-4 border-blue-400 rounded">
            <h3 class="text-lg font-semibold text-blue-800 mb-2">Current Settings</h3>
            <p class="text-blue-700">
                <strong>Timezone:</strong> {{ current_timezone }}
            </p>
            <p class="text-blue-700 text-sm mt-1">
                Current time in your timezone: <span id="current-time" class="font-mono"></span>
            </p>
        </div>

        <!-- Timezone Selection Form -->
        <form method="post" action="/worklog/timezone" class="space-y-6">
            <div>
                <label for="timezone" class="block text-sm font-medium text-gray-700 mb-2">
                    Select Your Timezone
                </label>
                <select 
                    name="timezone" 
                    id="timezone" 
                    required
                    class="w-full p-3 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                >
                    {% for timezone in timezones %}
                        <option value="{{ timezone.0 }}" {% if timezone.0 == current_timezone %}selected{% endif %}>
                            {{ timezone.1 }}
                        </option>
                    {% endfor %}
                </select>
                <p class="mt-2 text-sm text-gray-500">
                    Choose the timezone that matches your location for accurate time display.
                </p>
            </div>

            <div class="flex space-x-4">
                <button 
                    type="submit" 
                    class="bg-green-500 hover:bg-green-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200"
                >
                    Update Timezone
                </button>
                <a 
                    href="/worklog/" 
                    class="bg-gray-500 hover:bg-gray-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200"
                >
                    Cancel
                </a>
            </div>
        </form>

        <!-- Information Section -->
        <div class="mt-8 p-4 bg-yellow-50 border-l-4 border-yellow-400 rounded">
            <h3 class="text-lg font-semibold text-yellow-800 mb-2">Important Information</h3>
            <ul class="text-yellow-700 space-y-1 text-sm">
                <li>• All work time entries are stored in UTC for accuracy</li>
                <li>• Changing your timezone only affects how times are displayed</li>
                <li>• Duration calculations remain accurate regardless of timezone changes</li>
                <li>• Your preference is saved and will persist across sessions</li>
            </ul>
        </div>
    </div>
</div>

<script>
// Update current time display
function updateCurrentTime() {
    const now = new Date();
    const timeString = now.toLocaleString('en-US', {
        timeZone: '{{ current_timezone }}',
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false
    });
    document.getElementById('current-time').textContent = timeString;
}

// Update time immediately and then every second
updateCurrentTime();
setInterval(updateCurrentTime, 1000);

// Update preview when timezone selection changes
document.getElementById('timezone').addEventListener('change', function() {
    const selectedTimezone = this.value;
    const now = new Date();
    try {
        const timeString = now.toLocaleString('en-US', {
            timeZone: selectedTimezone,
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            hour12: false
        });
        document.getElementById('current-time').textContent = timeString + ' (Preview)';
    } catch (e) {
        document.getElementById('current-time').textContent = 'Invalid timezone';
    }
});
</script>
{% endblock %}