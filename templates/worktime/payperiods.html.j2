{% extends "worktime_base" %}

{% block content %}
<div class="flex justify-between items-center mb-8 animate-fade-in-up">
    <h1 class="text-3xl font-black text-white tracking-tighter">
        <i class="fas fa-calendar-alt me-2 text-hypr-cyan"></i>Pay Periods
    </h1>
    <a href="/worklog/" class="px-5 py-2 rounded-full bg-white/10 hover:bg-white/20 border border-white/10 text-white transition-all text-sm font-medium backdrop-blur-md">
        <i class="fas fa-arrow-left me-2"></i>Dashboard
    </a>
</div>

<!-- Create New Pay Period Section -->
<div class="glass-panel border-white/10 rounded-3xl p-8 mb-8 relative overflow-hidden shadow-2xl">
    <div class="absolute top-0 right-0 w-64 h-64 bg-hypr-cyan/10 blur-[80px] -z-10 rounded-full"></div>
    <div class="px-6 py-5 border-b border-white/10 mb-6 flex items-center">
        <h3 class="text-xl font-bold tracking-tight text-white flex items-center gap-3">
            <i class="fas fa-plus text-hypr-cyan"></i> Create New Pay Period
        </h3>
    </div>
    
    <form method="post" action="/worklog/payperiods" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="space-y-3 w-full">
                <label for="period_name" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-tag me-1 text-hypr-cyan"></i>Period Name
                </label>
                <input type="text" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan transition-all" id="period_name" name="period_name" placeholder="e.g., December 2024" required>
                <p class="text-xs text-slate-500 mt-1">Descriptive name for this period</p>
            </div>
            <div class="space-y-3 w-full">
                <label for="start_date" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-play me-1 text-hypr-cyan"></i>Start Date
                </label>
                <input type="date" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan transition-all [color-scheme:dark]" id="start_date" name="start_date" required>
            </div>
            <div class="space-y-3 w-full">
                <label for="end_date" class="block text-sm font-bold text-white tracking-widest uppercase">
                    <i class="fas fa-stop me-1 text-hypr-cyan"></i>End Date
                </label>
                <input type="date" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan transition-all [color-scheme:dark]" id="end_date" name="end_date" required>
            </div>
        </div>
        <div class="flex justify-end pt-4 border-t border-white/10">
            <button type="submit" class="glow-btn px-8 py-3 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-bold transition-transform hover:scale-105 shadow-[0_0_20px_rgba(0,168,244,0.3)] inline-flex items-center gap-2">
                <i class="fas fa-calendar-plus text-hypr-cyan"></i> Create Period
            </button>
        </div>
    </form>
</div>

<!-- Auto-assign Unassigned Entries -->
{% if unassigned_count is defined and unassigned_count > 0 %}
<div class="glass-panel border-yellow-500/30 bg-yellow-500/5 rounded-3xl p-8 mb-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div>
        <h3 class="text-lg font-bold text-white mb-2 flex items-center gap-2">
            <i class="fas fa-magic text-yellow-400"></i> Auto-assign Entries
        </h3>
        <p class="text-slate-300">You have <strong class="text-white">{{ unassigned_count }}</strong> unassigned time entries.</p>
        <p class="text-xs text-slate-400 mt-1">Automatically assign them to appropriate pay periods based on their dates.</p>
    </div>
    <form method="post" action="/worklog/payperiods/assign">
        <button type="submit" class="px-6 py-3 rounded-full bg-yellow-500/20 hover:bg-yellow-500/30 border border-yellow-500/50 text-yellow-200 font-bold transition-all shadow-[0_0_20px_rgba(234,179,8,0.2)] inline-flex items-center gap-2">
            <i class="fas fa-magic"></i> Auto-Assign
        </button>
    </form>
</div>
{% endif %}

<!-- Existing Pay Periods -->
<div class="glass-panel border-white/10 rounded-3xl p-8 shadow-xl">
    <div class="px-6 py-5 border-b border-white/10 mb-6 flex items-center">
        <h3 class="text-xl font-bold tracking-tight text-white flex items-center gap-3">
            <i class="fas fa-list text-hypr-cyan"></i> Your Pay Periods
        </h3>
    </div>
    
    {% if pay_periods %}
        <div class="overflow-x-auto rounded-xl border border-white/5 bg-black/20">
            <table class="w-full text-left text-sm whitespace-nowrap">
                <thead class="uppercase tracking-wider text-xs text-slate-400 bg-white/5 border-b border-white/10">
                    <tr>
                        <th class="px-6 py-4 font-semibold">Period Name</th>
                        <th class="px-6 py-4 font-semibold">Date Range</th>
                        <th class="px-6 py-4 font-semibold">Status</th>
                        <th class="px-6 py-4 font-semibold hidden md:table-cell">Hours</th>
                        <th class="px-6 py-4 font-semibold hidden md:table-cell">Earnings</th>
                        <th class="px-6 py-4 font-semibold hidden lg:table-cell">Entries</th>
                        <th class="px-6 py-4 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5 text-slate-300">
                    {% for period in pay_periods %}
                    <tr class="hover:bg-white/5 transition-colors {% if period.is_current %}bg-green-500/5{% endif %}">
                        <td class="px-6 py-4 font-medium text-white">
                            {{ period.period_name }}
                            {% if period.is_current %}
                                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-green-500/20 text-green-400 text-[10px] font-bold uppercase tracking-widest border border-green-500/30 ml-2">
                                    <i class="fas fa-circle animate-pulse text-[6px]"></i>Current
                                </span>
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 text-slate-400 font-mono text-xs">
                            {{ period.start_date | date(format='%m/%d/%Y') }} - {{ period.end_date | date(format='%m/%d/%Y') }}
                        </td>
                        <td class="px-6 py-4">
                            {% if period.is_current or period.is_active %}
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-green-500/20 text-green-400 text-xs font-bold uppercase tracking-widest border border-green-500/30">
                                    <i class="fas fa-calendar-check"></i>Active
                                </span>
                            {% else %}
                                {% set now = date() %}
                                {% set end_date = period.end_date %}
                                {% if end_date < now %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white/10 text-slate-400 text-xs font-bold uppercase tracking-widest border border-white/20">
                                        <i class="fas fa-archive"></i>Completed
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-hypr-cyan/20 text-hypr-cyan text-xs font-bold uppercase tracking-widest border border-hypr-cyan/30">
                                        <i class="fas fa-clock"></i>Upcoming
                                    </span>
                                {% endif %}
                            {% endif %}
                        </td>
                        <td class="px-6 py-4 hidden md:table-cell font-mono">
                            {{ period.total_hours | round(precision=1) }}h
                        </td>
                        <td class="px-6 py-4 hidden md:table-cell font-mono text-green-400 font-medium">
                            {{ period.currency | default("$") }} {{ period.total_earnings | round(precision=2) }}
                        </td>
                        <td class="px-6 py-4 hidden lg:table-cell text-slate-400">
                            {{ period.entries_count }} entries
                        </td>
                        <td class="px-6 py-4 text-right space-x-2">
                            <button type="button" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-hypr-cyan/10 border border-hypr-cyan/30 hover:bg-hypr-cyan/20 text-hypr-cyan transition-all" onclick="viewPeriodDetails('{{ period.id }}', '{{ period.period_name }}')">
                                <i class="fas fa-eye"></i>
                            </button>
                            <form method="post" action="/worklog/payperiods/delete/{{ period.id }}" class="inline-block" onsubmit="return confirm('Are you sure you want to delete this pay period?')">
                                <button type="submit" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-red-500/10 border border-red-500/30 hover:bg-red-500/20 text-red-400 transition-all">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="text-center py-12">
            <i class="fas fa-calendar-alt text-slate-700 text-5xl mb-4"></i>
            <h4 class="text-xl font-bold text-white mb-2">No Pay Periods Yet</h4>
            <p class="text-slate-400 font-mono text-sm max-w-md mx-auto mb-6">// Create your first pay period to start organizing your work time entries. They help you track earnings over specific time ranges.</p>
        </div>
    {% endif %}
</div>

{% if flash %}
<div class="mt-6 p-4 rounded-xl glass-panel {% if flash[0] == 'success' %}border-green-500/50 shadow-[0_0_30px_rgba(34,197,94,0.2)]{% else %}border-red-500/50 shadow-[0_0_30px_rgba(239,68,68,0.2)]{% endif %} animate-fade-in-up">
    <p class="font-mono text-sm {% if flash[0] == 'success' %}text-green-400{% else %}text-red-400{% endif %} mb-1">// SYSTEM NOTICE</p>
    <p class="text-white">{{ flash[1] }}</p>
</div>
{% endif %}

{% endblock %}

{% block script %}
<script>
function viewPeriodDetails(id, name) {
    alert(`Pay Period: ${name}\n\nClick OK to view detailed breakdown.`);
    // window.location.href = `/worklog/entries?period=${id}`;
}

document.addEventListener('DOMContentLoaded', function() {
    const today = new Date().toISOString().split('T')[0];
    const startDateInput = document.getElementById('start_date');
    const endDateInput = document.getElementById('end_date');
    
    if (startDateInput && !startDateInput.value) {
        startDateInput.value = today;
    }
    
    if(startDateInput) {
        startDateInput.addEventListener('change', function() {
            const startDate = new Date(this.value);
            if (startDate && endDateInput && !endDateInput.value) {
                const endDate = new Date(startDate);
                endDate.setDate(endDate.getDate() + 13); // Default 2 weeks
                endDateInput.value = endDate.toISOString().split('T')[0];
            }
        });
    }
});
</script>
{% endblock %}