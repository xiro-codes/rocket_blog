{% extends "worktime_base" %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="worktime-title mb-0">
        <i class="fas fa-edit me-2"></i>Edit Work Time Entry
    </h1>
    <a href="/worktime/entries" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Entries
    </a>
</div>

<!-- Edit Entry Form -->
<div class="worktime-card">
    <div class="worktime-card-header">
        <h3 class="mb-0">
            <i class="fas fa-edit me-2"></i>Edit Entry Details
        </h3>
    </div>
    
    <form method="post" action="/worktime/entries/{{ entry.id }}/edit" class="row g-3">
        <div class="col-md-6">
            <label for="user_role_id" class="form-label">
                <i class="fas fa-user-tag me-1"></i>Role
            </label>
            <select class="form-control" id="user_role_id" name="user_role_id" required>
                <option value="">Select a role...</option>
                {% for role in roles %}
                    <option value="{{ role.id }}" {% if role.id == entry.user_role_id %}selected{% endif %}>
                        {{ role.role_name }} (${{ role.hourly_wage }}/hr)
                    </option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-6">
            <label for="start_time" class="form-label">
                <i class="fas fa-play me-1"></i>Start Time
            </label>
            <input type="datetime-local" class="form-control" id="start_time" name="start_time" value="{{ start_time_str }}" required>
        </div>
        <div class="col-md-6">
            <label for="end_time" class="form-label">
                <i class="fas fa-stop me-1"></i>End Time
            </label>
            <input type="datetime-local" class="form-control" id="end_time" name="end_time" value="{{ end_time_str }}" required>
        </div>
        <div class="col-12 text-center">
            <button type="submit" class="btn btn-success btn-lg me-2">
                <i class="fas fa-save me-2"></i>Update Entry
            </button>
            <a href="/worktime/entries" class="btn btn-secondary btn-lg">
                <i class="fas fa-times me-2"></i>Cancel
            </a>
        </div>
    </form>
</div>

{% if flash %}
<div class="alert alert-{{ flash[0] }} mt-3">
    <i class="fas fa-info-circle me-2"></i>{{ flash[1] }}
</div>
{% endif %}

{% endblock %}