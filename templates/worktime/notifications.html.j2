{% extends "worktime_base" %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white mb-0">
        <i class="fas fa-bell me-2"></i>Notification Settings
    </h1>
    <a href="/" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

<!-- Quick Actions -->
<div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm flex flex-wrap p-2 gap-2 my-6" style="margin: 1rem 0;">
    <div class="text-center mb-3">
        <h4 class="mt-2 text-lg text-gray-600 dark:text-gray-400">
            <i class="fas fa-compass me-2"></i>Quick Actions
        </h4>
    </div>
    <div class="row g-2">
        <div class="col-sm-6 col-lg-3">
            <a href="/" class="btn btn-outline-primary w-100" style="margin: 0.25rem 0;">
                <i class="fas fa-home me-2"></i>Dashboard
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/roles" class="btn btn-outline-primary w-100" style="margin: 0.25rem 0;">
                <i class="fas fa-user-tag me-2"></i>Manage Roles
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/entries" class="btn btn-outline-info w-100" style="margin: 0.25rem 0;">
                <i class="fas fa-list-ul me-2"></i>View Entries
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
            <a href="/settings" class="btn btn-outline-success w-100" style="margin: 0.25rem 0;">
                <i class="fas fa-cog me-2"></i>Settings
            </a>
        </div>
    </div>
</div>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 font-semibold">
        <h3 class="mb-0">
            <i class="fas fa-cog me-2"></i>Notification Preferences
        </h3>
    </div>
    
    <form method="post" action="/notifications">
        <!-- Time-based notifications -->
        <div class="card mb-3">
            <div class="card-header">
                <h5><i class="fas fa-clock me-2"></i>Time-Based Notifications</h5>
            </div>
            <div class="card-body">
                <div class="form-check mb-3">
                    <input 
                        class="form-check-input" 
                        type="checkbox" 
                        id="time_based_enabled" 
                        name="time_based_enabled" 
                        value="true"
                        {% if settings and settings.time_based_enabled %}checked{% endif %}
                    >
                    <label class="form-check-label" for="time_based_enabled">
                        Enable time-based notifications
                    </label>
                </div>
                <div class="form-group">
                    <label for="time_threshold_minutes" class="form-label">
                        Notify after (minutes):
                    </label>
                    <input 
                        type="number" 
                        class="form-control" 
                        id="time_threshold_minutes" 
                                    name="time_threshold_minutes" 
                                    min="15" 
                                    max="480" 
                                    step="15"
                                    value="{% if settings and settings.time_threshold_minutes %}{{ settings.time_threshold_minutes }}{% endif %}"
                                    placeholder="120"
                                >
                                <small class="form-text text-muted">Get notified after working for this many minutes (15-480 minutes)</small>
                            </div>
                        </div>
                    </div>

                    <!-- Earnings-based notifications -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5>💰 Earnings-Based Notifications</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input 
                                    class="form-check-input" 
                                    type="checkbox" 
                                    id="earnings_based_enabled" 
                                    name="earnings_based_enabled" 
                                    value="true"
                                    {% if settings and settings.earnings_based_enabled %}checked{% endif %}
                                >
                                <label class="form-check-label" for="earnings_based_enabled">
                                    Enable earnings-based notifications
                                </label>
                            </div>
                            <div class="row">
                                <div class="col-md-8">
                                    <label for="earnings_threshold" class="form-label">
                                        Notify after earning:
                                    </label>
                                    <input 
                                        type="number" 
                                        class="form-control" 
                                        id="earnings_threshold" 
                                        name="earnings_threshold" 
                                        min="1" 
                                        step="0.01"
                                        value="{% if settings and settings.earnings_threshold %}{{ settings.earnings_threshold }}{% endif %}"
                                        placeholder="100.00"
                                    >
                                </div>
                                <div class="col-md-4">
                                    <label for="currency" class="form-label">Currency:</label>
                                    <input 
                                        type="text" 
                                        class="form-control" 
                                        id="currency" 
                                        name="currency" 
                                        maxlength="3"
                                        value="{% if settings and settings.currency %}{{ settings.currency }}{% else %}USD{% endif %}"
                                        placeholder="USD"
                                    >
                                </div>
                            </div>
                            <small class="form-text text-muted">Get notified when you earn this amount in a single session</small>
                        </div>
                    </div>

                    <!-- Daily goal notifications -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h5>🎯 Daily Goal Notifications</h5>
                        </div>
                        <div class="card-body">
                            <div class="form-check mb-3">
                                <input 
                                    class="form-check-input" 
                                    type="checkbox" 
                                    id="daily_goal_enabled" 
                                    name="daily_goal_enabled" 
                                    value="true"
                                    {% if settings and settings.daily_goal_enabled %}checked{% endif %}
                                >
                                <label class="form-check-label" for="daily_goal_enabled">
                                    Enable daily goal notifications
                                </label>
                            </div>
                            <div class="form-group">
                                <label for="daily_hours_goal" class="form-label">
                                    Daily hours goal:
                                </label>
                                <input 
                                    type="number" 
                                    class="form-control" 
                                    id="daily_hours_goal" 
                                    name="daily_hours_goal" 
                                    min="0.5" 
                                    max="16" 
                                    step="0.5"
                                    value="{% if settings and settings.daily_hours_goal %}{{ settings.daily_hours_goal }}{% endif %}"
                                    placeholder="8.0"
                                >
                                <small class="form-text text-muted">Get notified when you reach your daily hours goal (0.5-16 hours)</small>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn btn-success">💾 Save Settings</button>
                        <a href="/" class="btn btn-secondary">🔙 Back to Dashboard</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 mb-4">
                <h4>📱 Browser Permissions</h4>
                <p class="text-muted">To receive notifications, you need to grant permission:</p>
                <button id="request-permission" class="btn btn-primary mb-2">🔔 Enable Notifications</button>
                <div id="permission-status" class="alert alert-info">
                    <small>Status: <span id="permission-text">Checking...</span></small>
                </div>
                
                <h5>ℹ️ How it works</h5>
                <ul class="list-unstyled">
                    <li>⏰ <strong>Time notifications:</strong> Remind you to take breaks</li>
                    <li>💰 <strong>Earnings notifications:</strong> Celebrate reaching earning milestones</li>
                    <li>🎯 <strong>Daily goals:</strong> Track progress toward daily targets</li>
                </ul>
                
                <div class="alert alert-warning">
                    <small><strong>Note:</strong> Notifications work even when the app is in the background!</small>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Check and request notification permission
function checkPermission() {
    const permissionText = document.getElementById('permission-text');
    const permissionStatus = document.getElementById('permission-status');
    
    if (!('Notification' in window)) {
        permissionText.textContent = 'Not supported';
        permissionStatus.className = 'alert alert-danger';
        return;
    }
    
    switch (Notification.permission) {
        case 'granted':
            permissionText.textContent = 'Granted ✅';
            permissionStatus.className = 'alert alert-success';
            break;
        case 'denied':
            permissionText.textContent = 'Denied ❌';
            permissionStatus.className = 'alert alert-danger';
            break;
        default:
            permissionText.textContent = 'Not requested';
            permissionStatus.className = 'alert alert-warning';
            break;
    }
}

document.getElementById('request-permission').addEventListener('click', function() {
    if ('Notification' in window) {
        Notification.requestPermission().then(function(permission) {
            checkPermission();
            if (permission === 'granted') {
                new Notification('Work Time Tracker', {
                    body: 'Notifications are now enabled! 🎉',
                    icon: '/static/icon-192x192.png'
                });
            }
        });
    }
});

// Check permission on page load
checkPermission();

// Test notification button (for development)
function testNotification() {
    if (Notification.permission === 'granted') {
        new Notification('Test Notification', {
            body: 'This is a test notification from Work Time Tracker',
            icon: '/static/icon-192x192.png'
        });
    }
}

// Auto-enable/disable threshold inputs based on checkboxes
document.getElementById('time_based_enabled').addEventListener('change', function() {
    document.getElementById('time_threshold_minutes').disabled = !this.checked;
});

document.getElementById('earnings_based_enabled').addEventListener('change', function() {
    document.getElementById('earnings_threshold').disabled = !this.checked;
    document.getElementById('currency').disabled = !this.checked;
});

document.getElementById('daily_goal_enabled').addEventListener('change', function() {
    document.getElementById('daily_hours_goal').disabled = !this.checked;
});

// Initialize disabled state on page load
document.addEventListener('DOMContentLoaded', function() {
    const timeCheckbox = document.getElementById('time_based_enabled');
    const earningsCheckbox = document.getElementById('earnings_based_enabled');
    const dailyCheckbox = document.getElementById('daily_goal_enabled');
    
    document.getElementById('time_threshold_minutes').disabled = !timeCheckbox.checked;
    document.getElementById('earnings_threshold').disabled = !earningsCheckbox.checked;
    document.getElementById('currency').disabled = !earningsCheckbox.checked;
    document.getElementById('daily_hours_goal').disabled = !dailyCheckbox.checked;
});
</script>
{% endblock %}
