{% extends "worktime_base" %}

{% block content %}
<div class="flex flex-col min-h-screen bg-gray-50 dark:bg-gray-900">
	<div class="flex-1 w-full max-w-5xl mx-auto p-4 sm:p-6 lg:p-8">
		<div class="text-center mb-4">
			<h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">🕐 Work Time Tracker</h1>
			<p class="mt-2 text-lg text-gray-600 dark:text-gray-400">Access your work time tracking dashboard and manage your sessions.</p>
		</div>

		<div class="row justify-content-center">
			<div class="col-md-6 col-lg-4">
				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
					<div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 font-semibold">
						<h3 class="text-center mb-0">Login to TimeTracker</h3>
					</div>
					<form action="/worklog/login" method="post">
						<div class="mb-3">
							<label for="username" class="form-label">Username</label>
							<input type="text" name="username" id="username" class="form-control" placeholder="Enter your username..." required />
						</div>
						
						<div class="mb-3">
							<label for="password" class="form-label">Password</label>
							<input type="password" name="password" id="password" class="form-control" placeholder="Enter your password..." required />
						</div>
						
						<div class="d-grid mb-3">
							<button type="submit" class="btn btn-primary">Sign In</button>
						</div>
						
						<div class="text-center">
							<a href="/worklog/register" class="btn btn-secondary btn-sm">Create Account</a>
						</div>
					</form>
				</div>
			</div>
		</div>

		{% if flash %}
		<div class="row justify-content-center">
			<div class="col-md-6 col-lg-4">
				<div class="alert alert-{{ flash[0] }} text-center">
					{{ flash[1] }}
				</div>
			</div>
		</div>
		{% endif %}

		<div class="row justify-content-center mt-4">
			<div class="col-md-8 col-lg-6">
				<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
					<h4 class="text-center mb-3">📊 Work Time Tracker Features</h4>
					<div class="row">
						<div class="col-md-6">
							<ul class="list-unstyled">
								<li class="mb-2">⏰ Track work time with role-based hourly wages</li>
								<li class="mb-2">📊 Manage pay periods and view earnings</li>
								<li class="mb-2">🔔 Configurable notifications for time and earnings</li>
							</ul>
						</div>
						<div class="col-md-6">
							<ul class="list-unstyled">
								<li class="mb-2">📱 Progressive Web App with offline support</li>
								<li class="mb-2">🎯 Set daily goals and productivity targets</li>
								<li class="mb-2">💰 Comprehensive earnings reports</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

{% endblock %}