{% extends "worktime_base" %}
{% import "worktime_macros" as wt %}

{% block content %}
{{ wt.quick_nav(current_page="dashboard") }}

{{ wt.worktime_hero(
    title="Work Time Dashboard", 
    subtitle="Welcome back! Track your productive hours with ease", 
    username=username
) }}

<!-- Active Timer Section -->
{% call wt.worktime_card(title="Active Timer", icon="fas fa-play-circle") %}
    {{ wt.timer_display(active_entry=active_entry, roles=roles) }}
{% endcall %}

<!-- Summary Stats -->
{{ wt.stats_grid(stats=summary) }}

<!-- Recent Entries -->
{% call wt.worktime_card(title="Recent Entries", icon="fas fa-history") %}
    {{ wt.entries_table(entries=recent_entries) }}
    {% if recent_entries %}
        <div class="text-center">
            <a href="/entries" class="btn btn-primary">
                <i class="fas fa-arrow-right me-2"></i>View All Entries
            </a>
        </div>
    {% endif %}
{% endcall %}

{% endblock %}

{% block script %}
<!-- Include Work Time utilities -->
<script src="/static/worktime-utils.js"></script>
<script>
// Page-specific initialization
document.addEventListener('DOMContentLoaded', () => {
    // Enhanced timer updates if active entry exists
    {% if active_entry %}
    const timerElement = document.getElementById('live-timer');
    if (timerElement && timerElement.dataset.startTime) {
        WorkTimeUtils.Timer.startTimerUpdates('live-timer', timerElement.dataset.startTime);
    }
    {% endif %}
    
    // Enhanced stats auto-refresh
    WorkTimeUtils.AutoRefresh.startStatsRefresh(5000);
});
</script>
{% endblock %}
