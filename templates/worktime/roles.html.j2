{% extends "worktime_base" %}
{% import "worktime_macros" as wt %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="worktime-title mb-0">
        <i class="fas fa-user-tag me-2"></i>Manage Roles
    </h1>
    <a href="/worktime" class="btn btn-secondary">
        <i class="fas fa-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

{{ wt::quick_nav(current_page="roles", show_mobile_menu=false) }}

<!-- Add New Role -->
{% call wt::worktime_card(title="Add New Role", icon="fas fa-plus") %}
    <form method="post" action="/worktime/roles" class="row g-3">
        {{ wt::form_field_simple(
            type="text", 
            name="role_name", 
            label="Role Name", 
            icon="fas fa-briefcase",
            placeholder="e.g., Developer, Designer",
            required=true
        ) }}
        
        <div class="col-md-3">
            <label for="hourly_wage" class="form-label">
                <i class="fas fa-dollar-sign me-1"></i>Hourly Wage
            </label>
            <input type="number" step="0.01" class="form-control" id="hourly_wage" name="hourly_wage" placeholder="25.00" required>
        </div>
        
        {{ wt::select_field(
            name="currency",
            label="Currency",
            icon="fas fa-coins",
            required=true,
            options=[
                {value: "USD", text: "USD ($)"},
                {value: "EUR", text: "EUR (€)"},
                {value: "GBP", text: "GBP (£)"},
                {value: "CAD", text: "CAD ($)"},
                {value: "AUD", text: "AUD ($)"}
            ]
        ) }}
        
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="is_tipped" name="is_tipped" value="true">
                <label class="form-check-label" for="is_tipped">
                    <i class="fas fa-hand-holding-usd me-1"></i>Tipped Role
                </label>
            </div>
        </div>
        <div class="col-12 text-center">
            <button type="submit" class="btn btn-success">
                <i class="fas fa-plus me-2"></i>Add Role
            </button>
        </div>
    </form>
{% endcall %}

<!-- Existing Roles -->
{% call wt::worktime_card(title="Your Roles", icon="fas fa-list") %}
    {% if roles %}
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Role Name</th>
                        <th>Hourly Wage</th>
                        <th class="d-none d-sm-table-cell">Type</th>
                        <th class="d-none d-md-table-cell">Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for role in roles %}
                    <tr>
                        <td>
                            <i class="fas fa-briefcase me-2 text-primary"></i>
                            <strong>{{ role.role_name }}</strong>
                        </td>
                        <td>
                            <span class="badge" style="background-color: var(--success); color: var(--text-primary);">
                                {{ wt::format_currency(role.hourly_wage, role.currency) }}/hr
                            </span>
                        </td>
                        <td class="d-none d-sm-table-cell">
                            {% if role.is_tipped %}
                                <span class="badge bg-warning text-dark">
                                    <i class="fas fa-hand-holding-usd me-1"></i>Tipped
                                </span>
                            {% else %}
                                <span class="badge bg-secondary">
                                    <i class="fas fa-clock me-1"></i>Hourly
                                </span>
                            {% endif %}
                        </td>
                        <td class="d-none d-md-table-cell text-muted">
                            {{ role.created_at | date(format='%m/%d/%Y') }}
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-warning btn-sm" onclick="editRole('{{ role.id }}', '{{ role.role_name }}', {{ role.hourly_wage }}, '{{ role.currency }}', {{ role.is_tipped | lower }})">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <form method="post" action="/worktime/roles/delete/{{ role.id }}" class="d-inline" 
                                      onsubmit="return confirm('Are you sure you want to delete this role?')">
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% else %}
        <div class="text-center">
            <i class="fas fa-user-tag text-muted" style="font-size: 3rem; opacity: 0.3;"></i>
            <p class="text-muted mt-3">No roles created yet. Add your first role to start tracking work time!</p>
        </div>
    {% endif %}
{% endcall %}

<!-- Edit Role Modal (if needed) -->
<div class="modal fade" id="editRoleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit me-2"></i>Edit Role
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="editRoleForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="edit_role_name" class="form-label">Role Name</label>
                        <input type="text" class="form-control" id="edit_role_name" name="role_name" required>
                    </div>
                    <div class="mb-3">
                        <label for="edit_hourly_wage" class="form-label">Hourly Wage</label>
                        <input type="number" step="0.01" class="form-control" id="edit_hourly_wage" name="hourly_wage" required>
                    </div>
                    <div class="mb-3">
                        <label for="edit_currency" class="form-label">Currency</label>
                        <select class="form-control" id="edit_currency" name="currency" required>
                            <option value="USD">USD ($)</option>
                            <option value="EUR">EUR (€)</option>
                            <option value="GBP">GBP (£)</option>
                            <option value="CAD">CAD ($)</option>
                            <option value="AUD">AUD ($)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="edit_is_tipped" name="is_tipped" value="true">
                            <label class="form-check-label" for="edit_is_tipped">
                                <i class="fas fa-hand-holding-usd me-1"></i>Tipped Role
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% if flash %}
<div class="alert alert-{{ flash.0 }} mt-3">
    <i class="fas fa-info-circle me-2"></i>{{ flash.1 }}
</div>
{% endif %}



<div class="container-fluid">
    <!-- Tips -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="terminal-box">
                <h3>💡 Tips</h3>
                <ul>
                    <li><strong>Multiple Roles:</strong> Create different roles for different types of work or clients</li>
                    <li><strong>Accurate Rates:</strong> Set realistic hourly rates based on your experience and market rates</li>
                    <li><strong>Regular Updates:</strong> Update your rates as your skills and experience grow</li>
                    <li><strong>Currency Consistency:</strong> Use the same currency for all roles to get accurate totals</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block script %}
<script>
function editRole(id, name, wage, currency, isTipped) {
    const modal = new bootstrap.Modal(document.getElementById('editRoleModal'));
    const form = document.getElementById('editRoleForm');
    
    form.action = `/roles/edit/${id}`;
    document.getElementById('edit_role_name').value = name;
    document.getElementById('edit_hourly_wage').value = wage;
    document.getElementById('edit_currency').value = currency;
    document.getElementById('edit_is_tipped').checked = isTipped;
    
    modal.show();
}
</script>
{% endblock %}
