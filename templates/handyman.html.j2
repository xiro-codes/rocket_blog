<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pro Handyman Services</title>
    <script src="/static/tailwindcss.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            blue: '#2563eb',
                            light: '#eff6ff',
                            dark: '#1e40af',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">
    
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex-shrink-0 flex items-center">
                    <span class="text-2xl font-bold text-brand-blue">Pro Handyman</span>
                </div>
                <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
                    <a href="#services" class="text-gray-600 hover:text-brand-blue px-3 py-2 rounded-md text-sm font-medium">Services</a>
                    <a href="#about" class="text-gray-600 hover:text-brand-blue px-3 py-2 rounded-md text-sm font-medium">About</a>
                    <a href="#contact" class="text-gray-600 hover:text-brand-blue px-3 py-2 rounded-md text-sm font-medium">Contact</a>
                </div>
                <div>
                    <a href="tel:5551234567" class="bg-brand-blue text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-brand-dark transition">(555) 123-4567</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <div class="relative bg-white overflow-hidden">
        <div class="max-w-7xl mx-auto">
            <div class="relative z-10 pb-8 bg-white sm:pb-16 md:pb-20 lg:max-w-2xl lg:w-full lg:pb-28 xl:pb-32">
                <main class="mt-10 mx-auto max-w-7xl px-4 sm:mt-12 sm:px-6 md:mt-16 lg:mt-20 lg:px-8 xl:mt-28">
                    <div class="sm:text-center lg:text-left">
                        <h1 class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl">
                            <span class="block xl:inline">Reliable Handyman</span>
                            <span class="block text-brand-blue">for every project</span>
                        </h1>
                        <p class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-lg sm:max-w-xl sm:mx-auto md:mt-5 md:text-xl lg:mx-0">
                            From TV mounting and furniture delivery to plumbing repairs and drywall patching. We get the job done right, on time, and on budget.
                        </p>
                        <div class="mt-5 sm:mt-8 sm:flex sm:justify-center lg:justify-start">
                            <div class="rounded-md shadow">
                                <a href="#contact" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-brand-blue hover:bg-brand-dark md:py-4 md:text-lg transition">
                                    Get a Free Quote
                                </a>
                            </div>
                            <div class="mt-3 sm:mt-0 sm:ml-3">
                                <a href="#services" class="w-full flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-brand-blue bg-brand-light hover:bg-blue-100 md:py-4 md:text-lg transition">
                                    Our Services
                                </a>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
        </div>
        <div class="lg:absolute lg:inset-y-0 lg:right-0 lg:w-1/2">
            <img class="h-56 w-full object-cover sm:h-72 md:h-96 lg:w-full lg:h-full" src="https://via.placeholder.com/800x600?text=Handyman+Working" alt="Handyman working">
        </div>
    </div>

    <!-- Services Section -->
    <div id="services" class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center">
                <h2 class="text-base text-brand-blue font-semibold tracking-wide uppercase">Services</h2>
                <p class="mt-2 text-3xl leading-8 font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                    Everything you need done
                </p>
                <p class="mt-4 max-w-2xl text-xl text-gray-500 mx-auto">
                    No job is too big or too small. We tackle your to-do list so you don't have to.
                </p>
            </div>

            <div class="mt-10">
                <div class="space-y-10 md:space-y-0 md:grid md:grid-cols-2 lg:grid-cols-4 md:gap-x-8 md:gap-y-10">
                    
                    <!-- Service 1 -->
                    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition">
                        <img src="https://via.placeholder.com/400x300?text=TV+Mounting" alt="TV Mounting" class="w-full h-40 object-cover rounded-md mb-4">
                        <h3 class="text-lg font-medium text-gray-900">TV Mounting</h3>
                        <p class="mt-2 text-base text-gray-500">
                            Secure and level TV mounting on any wall type. We hide wires and optimize viewing angles.
                        </p>
                    </div>

                    <!-- Service 2 -->
                    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition">
                        <img src="https://via.placeholder.com/400x300?text=Furniture+Delivery" alt="Furniture Delivery & Assembly" class="w-full h-40 object-cover rounded-md mb-4">
                        <h3 class="text-lg font-medium text-gray-900">Furniture Assembly</h3>
                        <p class="mt-2 text-base text-gray-500">
                            Quick and correct assembly of flat-pack furniture, from beds to complex shelving units.
                        </p>
                    </div>

                    <!-- Service 3 -->
                    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition">
                        <img src="https://via.placeholder.com/400x300?text=Plumbing+Repairs" alt="Plumbing" class="w-full h-40 object-cover rounded-md mb-4">
                        <h3 class="text-lg font-medium text-gray-900">Minor Plumbing</h3>
                        <p class="mt-2 text-base text-gray-500">
                            Fixing leaky faucets, replacing fixtures, unclogging drains, and toilet repairs.
                        </p>
                    </div>

                    <!-- Service 4 -->
                    <div class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition">
                        <img src="https://via.placeholder.com/400x300?text=Drywall+Patching" alt="Drywall" class="w-full h-40 object-cover rounded-md mb-4">
                        <h3 class="text-lg font-medium text-gray-900">Drywall & Painting</h3>
                        <p class="mt-2 text-base text-gray-500">
                            Patching holes, repairing water damage, and interior painting touch-ups.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact Section -->
    <div id="contact" class="bg-white py-16 px-4 overflow-hidden sm:px-6 lg:px-8 lg:py-24">
        <div class="relative max-w-xl mx-auto">
            <div class="text-center">
                <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 sm:text-4xl">
                    Ready to get started?
                </h2>
                <p class="mt-4 text-lg leading-6 text-gray-500">
                    Fill out the form below or give us a call to discuss your project.
                </p>
            </div>
            <div class="mt-12">
                <form action="#" method="POST" class="grid grid-cols-1 gap-y-6">
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
                        <div class="mt-1">
                            <input type="text" name="name" id="name" class="py-3 px-4 block w-full shadow-sm focus:ring-brand-blue focus:border-brand-blue border-gray-300 rounded-md border" placeholder="John Doe">
                        </div>
                    </div>
                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
                        <div class="mt-1">
                            <input type="email" name="email" id="email" class="py-3 px-4 block w-full shadow-sm focus:ring-brand-blue focus:border-brand-blue border-gray-300 rounded-md border" placeholder="john@example.com">
                        </div>
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-medium text-gray-700">Project Details</label>
                        <div class="mt-1">
                            <textarea id="message" name="message" rows="4" class="py-3 px-4 block w-full shadow-sm focus:ring-brand-blue focus:border-brand-blue border border-gray-300 rounded-md" placeholder="Tell us what you need help with..."></textarea>
                        </div>
                    </div>
                    <div>
                        <button type="submit" class="w-full inline-flex items-center justify-center px-6 py-3 border border-transparent rounded-md shadow-sm text-base font-medium text-white bg-brand-blue hover:bg-brand-dark focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-blue transition">
                            Request Quote
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-800">
        <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center">
                <span class="text-xl font-bold text-white">Pro Handyman</span>
                <p class="text-gray-300 text-sm">&copy; 2026 Pro Handyman Services. All rights reserved.</p>
            </div>
        </div>
    </footer>
</body>
</html>