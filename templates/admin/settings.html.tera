{% extends "base" %}

{% block title %}Admin Settings{% endblock title %}

{% block content %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="mb-4">⚙️ Admin Settings</h1>
            
            <nav class="mb-4">
                <div class="nav nav-tabs" id="nav-tab" role="tablist">
                    <a class="nav-link active" href="/admin/settings">Settings</a>
                    <a class="nav-link" href="/admin/generate">Generate Post</a>
                </div>
            </nav>

            <div class="card">
                <div class="card-header">
                    <h3>🤖 OpenAI Configuration</h3>
                </div>
                <div class="card-body">
                    <form method="post" action="/admin/settings">
                        <div class="mb-3">
                            <label for="openai_api_key" class="form-label">OpenAI API Key</label>
                            <input 
                                type="password" 
                                class="form-control" 
                                id="openai_api_key" 
                                name="openai_api_key" 
                                value="{% if settings %}{{ settings.openai_api_key | default(value="") }}{% endif %}"
                                placeholder="sk-..."
                                required
                            >
                            <div class="form-text">
                                Your OpenAI API key. Get one from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="openai_base_prompt" class="form-label">Base Prompt</label>
                            <textarea 
                                class="form-control" 
                                id="openai_base_prompt" 
                                name="openai_base_prompt" 
                                rows="6"
                                placeholder="You are a helpful assistant that writes engaging blog posts..."
                                required
                            >{% if settings %}{{ settings.openai_base_prompt | default(value="") }}{% endif %}</textarea>
                            <div class="form-text">
                                This prompt will be used as the base instruction for generating blog posts.
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary">💾 Save Settings</button>
                        <a href="/admin/generate" class="btn btn-outline-success ms-2">🚀 Generate Post</a>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h3>📝 Quick Setup Guide</h3>
                </div>
                <div class="card-body">
                    <ol>
                        <li><strong>Get OpenAI API Key:</strong> Visit <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a> and create an API key</li>
                        <li><strong>Set Base Prompt:</strong> Write a prompt that describes the style and tone you want for your blog posts</li>
                        <li><strong>Save Settings:</strong> Click the save button to store your configuration</li>
                        <li><strong>Generate Posts:</strong> Use the Generate Post feature to create AI-powered content</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock content %}