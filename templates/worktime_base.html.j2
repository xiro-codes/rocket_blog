<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
		
		<!-- SEO Meta Tags -->
		<title>{% if page_title %}{{ page_title }}{% else %}Work Time Tracker - Professional Time Management{% endif %}</title>
		<meta name="description" content="{% if page_description %}{{ page_description }}{% else %}Professional work time tracking application with role-based wages, notifications, and comprehensive reporting.{% endif %}">
		<meta name="keywords" content="{% if page_keywords %}{{ page_keywords }}{% else %}time tracking, work time, productivity, wages, time management, professional{% endif %}">
		<meta name="author" content="Work Time Tracker">
		
		<!-- Canonical URL -->
		<link rel="canonical" href="{% if canonical_url %}{{ canonical_url }}{% else %}/{% endif %}">
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content="{% if page_title %}{{ page_title }}{% else %}Work Time Tracker{% endif %}">
		<meta property="og:description" content="{% if page_description %}{{ page_description }}{% else %}Professional work time tracking application{% endif %}">
		<meta property="og:type" content="website">
		<meta property="og:url" content="{% if canonical_url %}{{ canonical_url }}{% else %}/{% endif %}">
		<meta property="og:site_name" content="Work Time Tracker">
		<meta property="og:locale" content="en_US">
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary">
		<meta name="twitter:title" content="{% if page_title %}{{ page_title }}{% else %}Work Time Tracker{% endif %}">
		<meta name="twitter:description" content="{% if page_description %}{{ page_description }}{% else %}Professional work time tracking application{% endif %}">
		
		<!-- PWA Manifest -->
		<link rel="manifest" href="/static/manifest.json">
		
		<!-- PWA Meta Tags -->
		<meta name="mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="default">
		<meta name="apple-mobile-web-app-title" content="TimeTracker">
		<meta name="msapplication-TileColor" content="#00ff41">
		<meta name="msapplication-tap-highlight" content="no">
		<meta name="theme-color" content="#00ff41">
		
		<!-- PWA Icons -->
		<link rel="apple-touch-icon" href="/static/icon-192x192.png">
		<link rel="icon" type="image/png" sizes="192x192" href="/static/icon-192x192.png">
		<link rel="icon" type="image/png" sizes="512x512" href="/static/icon-512x512.png">
		
		<!-- Tailwind CSS and HTMX -->
		<script src="https://cdn.tailwindcss.com"></script>
		<script src="https://unpkg.com/htmx.org@1.9.10"></script>
		
		<!-- Custom Worktime CSS -->
		<link rel="stylesheet" href="/static/worktime.css" />
		
		<!-- Font Awesome for icons -->
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
	</head>

	<body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 font-sans antialiased selection:bg-green-200 selection:text-green-900 min-h-screen">
		<div class="container mx-auto max-w-5xl">
			<div class="p-4 sm:p-6 lg:p-8">
				{% block content %}
				{% endblock %}
			</div>
		</div>

		<!-- PWA Service Worker Registration -->
		<script>
			// Register service worker for PWA functionality
			if ('serviceWorker' in navigator) {
				window.addEventListener('load', () => {
					navigator.serviceWorker.register('/static/sw.js')
						.then((registration) => {
							console.log('SW registered: ', registration);
							
							// Check for updates
							registration.addEventListener('updatefound', () => {
								const newWorker = registration.installing;
								newWorker.addEventListener('statechange', () => {
									if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
										// New update available
										console.log('New version available! Please refresh.');
									}
								});
							});
						})
						.catch((registrationError) => {
							console.log('SW registration failed: ', registrationError);
						});
				});
			}
		</script>
		
		{% block script %}
		{% endblock %}
	</body>

</html>