{% extends "base" %}

{% block content %}
{%if post%}
<center>
	<h1>Edit Article</h1>
</center>
<div class="d-flex justify-content-center align-items-center bg-body-secondary">
	<form action="{{form_url}}" method="post">
		<div>
			<label for="title" class="form-label"> Title </label>
			<input type="text" class="form-control" name="title" id="title" value="{{post.title}}" />
		</div>
		<div>
			<label for="excerpt" class="form-label"> Excerpt </label>
			<textarea name="excerpt" id="excerpt" rows="3" class="form-control" placeholder="Brief summary of the post (optional - will be auto-generated if left empty)">{% if post.excerpt %}{{post.excerpt}}{% endif %}</textarea>
			<div class="form-text">Optional short summary that will appear in post listings. If left empty, it will be auto-generated from the content.</div>
		</div>
		<div>
			<label for="text" class="form-label"> Text </label>
			<textarea name="text" class="form-control" id="text" rows="8" >{{post.text}}</textarea>
		</div>
    <div class="mb-3">
      <label for="tags"  class="form-label">Tags (comma-separated)</label>
      <input type="text" class="form-control" name="tags" id="tags" placeholder="e.g. rust, web development, tutorial" value="{% for tag in tags %}{{ tag.name }}{% if not loop.last %}, {% endif %}{% endfor %}">
      <div class="form-text"> Separate multiple tags with commas</div>
    </div>
		<div class="justify-content-center d-flex m-1">
			<button type="submit" class="btn btn-primary">Submit</button>
		</div>
	</form>
</div>
{% if flash %}
<small class="field-{{ flash.0 }}-flash">
	{{ flash.1 }}
</small>
{% endif %}
{% endif %}
{% endblock %}
