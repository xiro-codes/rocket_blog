{% extends "base" %}

{% block content %}
<div class="max-w-4xl mx-auto py-8 animate-fade-in-up">
	{% if post %}
	<header class="mb-12 text-center">
		<h1 class="text-5xl font-black text-white tracking-tighter">Modify Sequence</h1>
		<p class="text-hypr-cyan font-mono mt-4">>> Edit Existing Article</p>
	</header>

	<div class="glass-panel rounded-3xl border border-white/10 p-8 md:p-12 relative overflow-hidden shadow-2xl shadow-hypr-cyan/5">
		<!-- Glow background -->
		<div class="absolute top-0 right-0 w-64 h-64 bg-hypr-cyan/10 blur-[80px] -z-10 rounded-full"></div>
		<div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 blur-[80px] -z-10 rounded-full"></div>

		<form action="{{form_url}}" method="post" enctype="multipart/form-data" class="space-y-8 relative z-10 mx-auto max-w-2xl">
			
			<!-- Title -->
			<div class="space-y-3">
				<label for="title" class="block text-sm font-bold text-white tracking-widest uppercase">Post Title</label>
				<div class="flex flex-col sm:flex-row gap-3">
					<input type="text" name="title" id="title" value="{{post.title}}" class="flex-1 px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-600" placeholder="Enter sequence name..." />
					{% if ai_available %}
					<button type="button" id="generate-content-btn" class="glow-btn px-6 py-4 rounded-xl bg-hypr-dark border border-hypr-cyan/50 text-white font-medium transition-transform hover:scale-[1.02] whitespace-nowrap flex items-center gap-2">
						<span class="text-hypr-cyan">✨</span> Generate
					</button>
					{% endif %}
				</div>
			</div>
			
			<!-- AI Prompt -->
			{% if ai_available %}
			<div id="ai-prompt-section" style="display: none;" class="bg-hypr-cyan/5 border border-hypr-cyan/20 p-5 rounded-xl backdrop-blur-md">
				<label for="ai-prompt" class="block text-xs font-mono text-hypr-cyan mb-2">>> AI Context Prompt (Optional)</label>
				<input type="text" id="ai-prompt" class="w-full px-4 py-3 bg-black/50 border border-white/10 rounded-lg text-white text-sm focus:outline-none focus:border-hypr-cyan transition-all placeholder:text-slate-600" placeholder="Provide additional parameters..." />
			</div>
			{% endif %}
			
			<!-- Excerpt -->
			<div class="space-y-3">
				<label for="excerpt" class="block text-sm font-bold text-white tracking-widest uppercase">Excerpt</label>
				<div class="flex flex-col gap-3">
					<textarea name="excerpt" id="excerpt" rows="3" class="w-full px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-600 resize-y" placeholder="Brief summary (auto-generated if empty)">{% if post.excerpt %}{{post.excerpt}}{% endif %}</textarea>
					{% if ai_available %}
					<button type="button" id="generate-excerpt-btn" class="self-start px-5 py-2 rounded-lg bg-white/5 border border-white/10 hover:border-hypr-cyan text-slate-300 hover:text-white transition-all text-sm font-medium flex items-center gap-2">
						<span class="text-hypr-cyan">✨</span> Auto-Excerpt
					</button>
					{% endif %}
				</div>
			</div>
			
			<!-- Content -->
			<div class="space-y-3">
				<label for="text" class="block text-sm font-bold text-white tracking-widest uppercase">Main Payload</label>
				<div class="rounded-xl overflow-hidden border border-white/10 bg-black/50 focus-within:border-hypr-cyan focus-within:ring-1 focus-within:ring-hypr-cyan transition-all">
					<textarea name="text" id="text" rows="12" class="w-full bg-transparent text-white">{{post.text}}</textarea>
				</div>
			</div>
			
			<!-- Media -->
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 p-6 rounded-2xl bg-white/5 border border-white/10 relative">
				<div class="space-y-3">
					<label for="file" class="block text-sm font-bold text-white tracking-widest uppercase">Upload Media</label>
					<input type="file" name="file" id="file" class="w-full px-4 py-3 bg-black/50 border border-white/10 rounded-xl text-slate-300 text-sm file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-white/10 file:text-white hover:file:bg-white/20 transition-all cursor-pointer" accept="video/*" />
				</div>
				
				<div class="hidden md:flex absolute inset-y-0 left-1/2 items-center justify-center -translate-x-1/2">
					<span class="bg-black text-hypr-cyan font-mono text-xs px-3 py-1 rounded-full border border-white/10">// OR //</span>
				</div>
				
				<div class="space-y-3">
					<label for="youtube_url" class="block text-sm font-bold text-white tracking-widest uppercase">YouTube Link</label>
					<input type="url" name="youtube_url" id="youtube_url" class="w-full px-5 py-3 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-600" placeholder="https://youtube.com/..." />
					<div id="youtube-status" class="text-xs font-mono text-slate-500 mt-2">Background download status tracking.</div>
				</div>
			</div>
			
			<!-- Tags -->
			<div class="space-y-3">
				<label for="tags" class="block text-sm font-bold text-white tracking-widest uppercase">System Tags</label>
				<div class="flex flex-col sm:flex-row gap-3">
					<input type="text" name="tags" id="tags" value="{% for tag in tags %}{{ tag.name }}{% if not loop.last %}, {% endif %}{% endfor %}" class="flex-1 px-5 py-4 bg-black/50 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-600 font-mono text-sm" placeholder="rust, web, backend">
					{% if ai_available %}
					<button type="button" id="generate-tags-btn" class="glow-btn px-6 py-4 rounded-xl bg-hypr-dark border border-hypr-cyan/50 text-white font-medium transition-transform hover:scale-[1.02] whitespace-nowrap flex items-center gap-2">
						<span class="text-hypr-cyan">✨</span> Gen Tags
					</button>
					{% endif %}
				</div>
			</div>
			
			<!-- Actions -->
			<div class="flex flex-col sm:flex-row justify-end gap-4 pt-8 border-t border-white/10">
				{% if post.draft %}
				<button type="submit" name="action" value="draft" class="px-8 py-3 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 text-white font-medium transition-all">Update Draft</button>
				<button type="submit" name="action" value="publish" class="glow-btn px-10 py-3 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-bold transition-transform hover:scale-105 shadow-[0_0_20px_rgba(0,168,244,0.3)]">Publish Sequence</button>
				{% else %}
				<button type="submit" name="action" value="draft" class="px-8 py-3 rounded-full bg-white/5 border border-white/10 hover:bg-white/10 text-white font-medium transition-all">Revert to Draft</button>
				<button type="submit" name="action" value="publish" class="glow-btn px-10 py-3 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-bold transition-transform hover:scale-105 shadow-[0_0_20px_rgba(0,168,244,0.3)]">Update Sequence</button>
				{% endif %}
			</div>
		</form>
	</div>
	{% endif %}
</div>

{% if flash %}
<div class="fixed bottom-6 right-6 p-4 rounded-xl glass-panel border border-hypr-cyan/50 text-white shadow-[0_0_30px_rgba(0,168,244,0.2)] z-50 animate-fade-in-up">
	<p class="font-mono text-sm text-hypr-cyan mb-1">// SYSTEM NOTICE</p>
	<p>{{ flash[1] }}</p>
</div>
{% endif %}
{% endblock %}

{% block script %}
{% if post %}
<script>
function htmlToMarkdown(html) {
	if (!html || typeof html !== 'string') return '';
	if (!/<\/?[a-z][\s\S]*>/i.test(html)) return html;
	
	let markdown = html;
	markdown = markdown.replace(/<h1[^>]*>(.*?)<\/h1>/gi, '# $1\n\n');
	markdown = markdown.replace(/<h2[^>]*>(.*?)<\/h2>/gi, '## $1\n\n');
	markdown = markdown.replace(/<h3[^>]*>(.*?)<\/h3>/gi, '### $1\n\n');
	markdown = markdown.replace(/<h4[^>]*>(.*?)<\/h4>/gi, '#### $1\n\n');
	markdown = markdown.replace(/<h5[^>]*>(.*?)<\/h5>/gi, '##### $1\n\n');
	markdown = markdown.replace(/<h6[^>]*>(.*?)<\/h6>/gi, '###### $1\n\n');
	markdown = markdown.replace(/<strong[^>]*>(.*?)<\/strong>/gi, '**$1**');
	markdown = markdown.replace(/<b[^>]*>(.*?)<\/b>/gi, '**$1**');
	markdown = markdown.replace(/<em[^>]*>(.*?)<\/em>/gi, '*$1*');
	markdown = markdown.replace(/<i[^>]*>(.*?)<\/i>/gi, '*$1*');
	markdown = markdown.replace(/<a[^>]*href=['"](.*?)['"][^>]*>(.*?)<\/a>/gi, '[$2]($1)');
	markdown = markdown.replace(/<img[^>]*src=['"](.*?)['"][^>]*alt=['"](.*?)['"][^>]*>/gi, '![$2]($1)');
	markdown = markdown.replace(/<img[^>]*alt=['"](.*?)['"][^>]*src=['"](.*?)['"][^>]*>/gi, '![$1]($2)');
	markdown = markdown.replace(/<img[^>]*src=['"](.*?)['"][^>]*>/gi, '![]($1)');
	markdown = markdown.replace(/<code[^>]*>(.*?)<\/code>/gi, '`$1`');
	markdown = markdown.replace(/<pre[^>]*><code[^>]*>(.*?)<\/code><\/pre>/gi, '```\n$1\n```');
	markdown = markdown.replace(/<pre[^>]*>(.*?)<\/pre>/gi, '```\n$1\n```');
	markdown = markdown.replace(/<ul[^>]*>(.*?)<\/ul>/gi, (m, c) => c.replace(/<li[^>]*>(.*?)<\/li>/gi, '- $1\n') + '\n');
	markdown = markdown.replace(/<ol[^>]*>(.*?)<\/ol>/gi, (m, c) => { let cnt = 1; return c.replace(/<li[^>]*>(.*?)<\/li>/gi, () => (cnt++) + '. ' + arguments[1] + '\n') + '\n'; });
	markdown = markdown.replace(/<blockquote[^>]*>(.*?)<\/blockquote>/gi, (m, c) => c.split('\n').map(l => '> ' + l.trim()).join('\n') + '\n\n');
	markdown = markdown.replace(/<br\s*\/?>/gi, '\n');
	markdown = markdown.replace(/<p[^>]*>(.*?)<\/p>/gi, '$1\n\n');
	markdown = markdown.replace(/<div[^>]*>(.*?)<\/div>/gi, '$1\n');
	markdown = markdown.replace(/<hr[^>]*>/gi, '\n---\n');
	markdown = markdown.replace(/<[^>]*>/g, '');
	markdown = markdown.replace(/\n{3,}/g, '\n\n');
	return markdown.trim();
}

document.addEventListener('DOMContentLoaded', function() {
	const textElement = document.getElementById('text');
	if (textElement && textElement.value) {
		textElement.value = htmlToMarkdown(textElement.value);
	}

	const easyMDE = new EasyMDE({
		element: textElement,
		spellChecker: false,
		autofocus: false,
		placeholder: 'Enter markdown payload...',
		toolbar: [
			'bold', 'italic', 'heading', '|',
			'quote', 'unordered-list', 'ordered-list', '|',
			'link', 'image', '|',
			'code', 'table', '|',
			'preview', 'side-by-side', 'fullscreen'
		],
		status: ['lines', 'words', 'cursor'],
	});

	// Handle file vs youtube mutual exclusion
	const fileInput = document.getElementById('file');
	const youtubeInput = document.getElementById('youtube_url');

	if (fileInput && youtubeInput) {
		fileInput.addEventListener('change', function() {
			if (this.files && this.files.length > 0) {
				youtubeInput.disabled = true;
				youtubeInput.value = '';
				youtubeInput.classList.add('opacity-50', 'cursor-not-allowed');
			} else {
				youtubeInput.disabled = false;
				youtubeInput.classList.remove('opacity-50', 'cursor-not-allowed');
			}
		});

		youtubeInput.addEventListener('input', function() {
			if (this.value.trim()) {
				fileInput.disabled = true;
				fileInput.classList.add('opacity-50', 'cursor-not-allowed');
			} else {
				fileInput.disabled = false;
				fileInput.classList.remove('opacity-50', 'cursor-not-allowed');
			}
		});
	}

	{% if ai_available %}
	// AI Generation scripts...
	const titleInput = document.getElementById('title');
	const promptInput = document.getElementById('ai-prompt');
	const promptSection = document.getElementById('ai-prompt-section');
	const generateContentBtn = document.getElementById('generate-content-btn');
	const generateExcerptBtn = document.getElementById('generate-excerpt-btn');
	const generateTagsBtn = document.getElementById('generate-tags-btn');
	const excerptTextarea = document.getElementById('excerpt');
	const tagsInput = document.getElementById('tags');

	if (titleInput && promptSection) {
		titleInput.addEventListener('input', function() {
			promptSection.style.display = this.value.trim() ? 'block' : 'none';
		});
	}

	if (generateContentBtn) {
		generateContentBtn.addEventListener('click', async function() {
			const title = titleInput.value.trim();
			if (!title) return alert('Enter a title first');

			const prompt = promptInput ? promptInput.value.trim() : null;
			this.disabled = true;
			this.innerHTML = '<span class="animate-spin inline-block">↻</span> Processing';

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ type: 'content', title: title, prompt: prompt })
				});
				const data = await response.json();
				if (data.success) easyMDE.value(data.content);
				else alert('Error: ' + (data.error || 'Unknown'));
			} catch (e) {
				alert('Error: ' + e.message);
			} finally {
				this.disabled = false;
				this.innerHTML = '<span class="text-hypr-cyan">✨</span> Generate';
			}
		});
	}

	if (generateExcerptBtn) {
		generateExcerptBtn.addEventListener('click', async function() {
			const content = easyMDE.value();
			if (!content.trim()) return alert('Enter content first');

			this.disabled = true;
			this.innerHTML = '<span class="animate-spin inline-block">↻</span> Processing';

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ type: 'excerpt', content: content })
				});
				const data = await response.json();
				if (data.success) excerptTextarea.value = data.excerpt;
				else alert('Error: ' + (data.error || 'Unknown'));
			} catch (e) {
				alert('Error: ' + e.message);
			} finally {
				this.disabled = false;
				this.innerHTML = '<span class="text-hypr-cyan">✨</span> Auto-Excerpt';
			}
		});
	}

	if (generateTagsBtn) {
		generateTagsBtn.addEventListener('click', async function() {
			const title = titleInput.value.trim();
			const content = easyMDE.value();
			if (!title && !content.trim()) return alert('Enter title or content');

			this.disabled = true;
			this.innerHTML = '<span class="animate-spin inline-block">↻</span> Processing';

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ type: 'tags', title: title, content: content })
				});
				const data = await response.json();
				if (data.success) tagsInput.value = data.tags;
				else alert('Error: ' + (data.error || 'Unknown'));
			} catch (e) {
				alert('Error: ' + e.message);
			} finally {
				this.disabled = false;
				this.innerHTML = '<span class="text-hypr-cyan">✨</span> Gen Tags';
			}
		});
	}
	{% endif %}

	function loadBackgroundJobStatus() {
		try {
			fetch(`/blog/{{post.seq_id}}/background-job-status`)
			.then(r => r.json())
			.then(data => {
				if (data.success && data.job) {
					const job = data.job;
					const s = document.getElementById('youtube-status');
					const y = document.getElementById('youtube_url');
					if (job.youtube_url && y) y.value = job.youtube_url;
					if (s) {
						if (job.status === 'completed') s.innerHTML = '<span class="text-hypr-teal">✅ Sequence downloaded</span>';
						else if (job.status === 'downloading') { s.innerHTML = '<span class="text-hypr-cyan animate-pulse">⬇️ Downloading...</span>'; setTimeout(loadBackgroundJobStatus, 5000); }
						else if (job.status === 'pending') { s.innerHTML = '<span class="text-amber-400">⏳ Pending...</span>'; setTimeout(loadBackgroundJobStatus, 5000); }
						else s.innerHTML = `<span class="text-red-500">❌ Failed: ${job.error_message||''}</span>`;
					}
				}
			});
		} catch(e){}
	}
	loadBackgroundJobStatus();
});
</script>
{% endif %}
{% endblock %}