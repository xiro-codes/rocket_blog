{% extends "base" %}

{% block content %}
<div class="row">
    <div class="col-12">
        <h1 class="text-center mb-4">{{ title }}</h1>

        <!-- Search Form -->
        <div class="d-flex justify-content-center align-items-center" >
            <form action="/blog/search" method="post">
                <h3 class="text-center mb-4">Search</h3>
                <div class="">
                    <input type="text"
                           class="form-control"
                           name="query"
                           value="{{ search_query }}"
                           placeholder="Search posts...">
                </div>
                <div class="">
                    <button type="submit"
                            class="btn btn-outline-success w-100">
                        Search
                    </button>
                </div>
            </form>
        </div>

        <!-- Search Results -->
        {% if search_query %}
            {% if results %}
                <div class="search-results">
                    <p class="mb-3">
                        Found {{ results | length }} result(s)
                        {% if num_pages > 1 %}(Page {{ page }} of {{ num_pages }}){% endif %}
                    </p>

                    {% for post in results %}
                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="/blog/{{ post.seq_id }}"
                                   class="text-decoration-none">
                                    {{ post.title }}
                                </a>
                            </h5>

                            <!-- Search ranking indicator -->
                            <small class="text-muted">
                                <span class="badge bg-secondary">
                                    Relevance: {{ (post.rank * 100) | round(precision=1) }}%
                                </span>
                            </small>

                            <!-- Highlighted excerpt or generated headline -->
                            <div class="card-text mt-2">
                                {% if post.headline %}
                                    <div class="search-headline">{{ post.headline | safe }}</div>
                                {% elif post.excerpt %}
                                    <div>{{ post.excerpt }}</div>
                                {% endif %}
                            </div>

                            <!-- Reaction counts -->
                            {% set summary = false %}
                            {% for reaction_summary in reaction_summaries %}
                                {% if reaction_summary.post_id == post.id %}
                                    {% set summary = reaction_summary %}
                                {% endif %}
                            {% endfor %}
                            {% if summary %}
                            <div class="reaction-summary mt-2">
                                <small class="text-muted">
                                    {% if summary.total_reactions > 0 %}
                                    <span class="reactions-count">
                                        👍 {{summary.total_reactions}} reaction{% if summary.total_reactions != 1 %}s{% endif %}
                                    </span>
                                    {% else %}
                                    <span class="reactions-count">No reactions yet</span>
                                    {% endif %}
                                </small>
                            </div>
                            {% endif %}

                            <div class="mt-2">
                                <a href="/blog/{{ post.seq_id }}"
                                   class="btn btn-sm btn-outline-success">
                                    Read more →
                                </a>
                            </div>
                        </div>
                    </div>
                    {% endfor %}

                    <!-- Pagination -->
                    {% if num_pages > 1 %}
                    <nav aria-label="Search results pagination">
                        <ul class="pagination justify-content-center">
                            {% if page > 1 %}
                            <li class="page-item">
                                <a class="page-link"
                                   href="/blog/search?query={{ search_query }}&page={{ page - 1 }}&page_size={{ page_size }}">
                                    Previous
                                </a>
                            </li>
                            {% endif %}

                            {% for page_num in range(start=1, end=num_pages + 1) %}
                                {% if page_num == page %}
                                <li class="page-item active">
                                    <span class="page-link active">
                                        {{ page_num }}
                                    </span>
                                </li>
                                {% else %}
                                <li class="page-item">
                                    <a class="page-link"
                                       href="/blog/search?query={{ search_query }}&page={{ page_num }}&page_size={{ page_size }}">
                                        {{ page_num }}
                                    </a>
                                </li>
                                {% endif %}
                            {% endfor %}

                            {% if page < num_pages %}
                            <li class="page-item">
                                <a class="page-link"
                                   href="/blog/search?query={{ search_query }}&page={{ page + 1 }}&page_size={{ page_size }}">
                                    Next
                                </a>
                            </li>
                            {% endif %}
                        </ul>
                    </nav>
                    {% endif %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <h4>No results found</h4>
                    <p>No posts match your search for "{{ search_query }}". Try different keywords or check your spelling.</p>
                </div>
            {% endif %}
        {% else %}
            <div class="alert alert-info">
                <h4>Search Blog Posts</h4>
                <p>Use the search form above to find posts by title, content, or excerpt. The search supports:</p>
                <ul>
                    <li>Full-text search across all post content</li>
                    <li>Relevance ranking</li>
                    <li>Highlighted search results</li>
                    <li>Multiple keywords</li>
                </ul>
            </div>
        {% endif %}

        <!-- Tag Cloud -->
        {% if all_tags %}
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">Browse by Tags</h5>
            </div>
            <div class="card-body">
                {% for tag in all_tags %}
                <a href="/blog/tag/{{ tag.slug }}"
                   class="badge text-decoration-none me-2 mb-2"
                   style="background-color: {{ tag.color }}; color: white;">
                    {{ tag.name }}
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>

<style>
.search-headline mark {
    background-color: #fdfdfc;
    color: #1c1c1c;
    padding: 2px 4px;
    font-weight: bold;
}
</style>
{% endblock %}
