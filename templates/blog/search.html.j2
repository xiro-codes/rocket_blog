{% extends "base" %}

{% block content %}
<div class="max-w-4xl mx-auto py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-center text-gray-900 dark:text-white tracking-tight mb-8">{{ title }}</h1>

        <!-- Search Form -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 md:p-8">
            <form action="/blog/search" method="post" class="max-w-2xl mx-auto">
                <h3 class="text-xl font-semibold text-center text-gray-900 dark:text-white mb-6">Search Posts</h3>
                <div class="flex flex-col sm:flex-row gap-3">
                    <div class="flex-grow">
                        <input type="text"
                               class="w-full px-4 py-3 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition text-lg"
                               name="query"
                               value="{{ search_query }}"
                               placeholder="Search posts...">
                    </div>
                    <div>
                        <button type="submit"
                                class="w-full sm:w-auto px-8 py-3 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg shadow-sm shadow-blue-500/30 transition text-lg">
                            Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Search Results -->
    {% if search_query %}
        {% if results %}
            <div class="space-y-6">
                <div class="flex justify-between items-center bg-gray-50 dark:bg-gray-800/50 px-4 py-3 rounded-lg border border-gray-200 dark:border-gray-700">
                    <p class="text-gray-700 dark:text-gray-300 font-medium">
                        Found <span class="text-blue-600 dark:text-blue-400 font-bold">{{ results | length }}</span> result(s)
                    </p>
                    {% if num_pages > 1 %}
                    <p class="text-sm text-gray-500 dark:text-gray-400">
                        Page {{ page }} of {{ num_pages }}
                    </p>
                    {% endif %}
                </div>

                <div class="grid gap-6">
                    {% for post in results %}
                    <article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-md transition p-6">
                        <header class="mb-3">
                            <h2 class="text-2xl font-bold mb-2">
                                <a href="/blog/{{ post.seq_id }}" class="text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition">
                                    {{ post.title }}
                                </a>
                            </h2>
                            <div class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 border border-gray-200 dark:border-gray-600">
                                Relevance: {{ (post.rank * 100) | round(precision=1) }}%
                            </div>
                        </header>

                        <!-- Highlighted excerpt or generated headline -->
                        <div class="text-gray-600 dark:text-gray-400 mb-4 search-content">
                            {% if post.headline %}
                                <div class="search-headline">{{ post.headline | safe }}</div>
                            {% elif post.excerpt %}
                                <div>{{ post.excerpt }}</div>
                            {% endif %}
                        </div>

                        <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
                            <!-- Reaction counts -->
                            {% set summary = false %}
                            {% for reaction_summary in reaction_summaries %}
                                {% if reaction_summary.post_id == post.id %}
                                    {% set summary = reaction_summary %}
                                {% endif %}
                            {% endfor %}
                            
                            <div class="text-sm text-gray-500 dark:text-gray-400">
                                {% if summary and summary.total_reactions > 0 %}
                                    <span class="flex items-center gap-1">
                                        👍 {{summary.total_reactions}} reaction{% if summary.total_reactions != 1 %}s{% endif %}
                                    </span>
                                {% else %}
                                    <span>No reactions yet</span>
                                {% endif %}
                            </div>

                            <a href="/blog/{{ post.seq_id }}" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium text-sm flex items-center gap-1">
                                Read more <span aria-hidden="true">&rarr;</span>
                            </a>
                        </div>
                    </article>
                    {% endfor %}
                </div>

                <!-- Pagination -->
                {% if num_pages > 1 %}
                <div class="mt-10 flex justify-center">
                    <nav class="inline-flex rounded-md shadow-sm -space-x-px" aria-label="Pagination">
                        {% if page > 1 %}
                        <a href="/blog/search?query={{ search_query }}&page={{ page - 1 }}&page_size={{ page_size }}" class="relative inline-flex items-center px-4 py-2 rounded-l-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                            Previous
                        </a>
                        {% endif %}

                        {% for page_num in range(start=1, end=num_pages + 1) %}
                            {% if page_num == page %}
                            <span class="relative inline-flex items-center px-4 py-2 border border-blue-500 bg-blue-50 dark:bg-blue-900/30 text-sm font-medium text-blue-600 dark:text-blue-400 z-10">
                                {{ page_num }}
                            </span>
                            {% else %}
                            <a href="/blog/search?query={{ search_query }}&page={{ page_num }}&page_size={{ page_size }}" class="relative inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                                {{ page_num }}
                            </a>
                            {% endif %}
                        {% endfor %}

                        {% if page < num_pages %}
                        <a href="/blog/search?query={{ search_query }}&page={{ page + 1 }}&page_size={{ page_size }}" class="relative inline-flex items-center px-4 py-2 rounded-r-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 transition">
                            Next
                        </a>
                        {% endif %}
                    </nav>
                </div>
                {% endif %}
            </div>
        {% else %}
            <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-6 text-center">
                <h4 class="text-xl font-bold text-blue-800 dark:text-blue-300 mb-2">No results found</h4>
                <p class="text-blue-600 dark:text-blue-400">No posts match your search for "<span class="font-bold">{{ search_query }}</span>". Try different keywords or check your spelling.</p>
            </div>
        {% endif %}
    {% else %}
        <div class="bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 rounded-lg p-6">
            <h4 class="text-xl font-bold text-indigo-900 dark:text-indigo-300 mb-3">Search Blog Posts</h4>
            <p class="text-indigo-700 dark:text-indigo-400 mb-3">Use the search form above to find posts by title, content, or excerpt. The search supports:</p>
            <ul class="list-disc list-inside text-indigo-700 dark:text-indigo-400 space-y-1">
                <li>Full-text search across all post content</li>
                <li>Relevance ranking</li>
                <li>Highlighted search results</li>
                <li>Multiple keywords</li>
            </ul>
        </div>
    {% endif %}

    <!-- Tag Cloud -->
    {% if all_tags %}
    <div class="mt-12 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50">
            <h5 class="font-bold text-gray-900 dark:text-white mb-0">Browse by Tags</h5>
        </div>
        <div class="p-6 flex flex-wrap gap-2">
            {% for tag in all_tags %}
            <a href="/blog/tag/{{ tag.slug }}"
               class="text-sm font-semibold px-3 py-1.5 rounded-full hover:opacity-80 transition text-white shadow-sm"
               style="background-color: {{ tag.color }};">
                {{ tag.name }}
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>

<style>
.search-headline mark {
    background-color: #fef08a; /* Tailwind yellow-200 */
    color: #854d0e; /* Tailwind yellow-800 */
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-weight: 600;
}
@media (prefers-color-scheme: dark) {
    .search-headline mark {
        background-color: #854d0e;
        color: #fef08a;
    }
}
</style>
{% endblock %}