{% extends "base" %}

{% block content %}
<div class="max-w-5xl mx-auto py-8 animate-fade-in-up">
    <div class="mb-12">
        <h1 class="text-5xl font-black text-center text-white tracking-tighter mb-8">{{ title }}</h1>

        <!-- Search Form -->
        <div class="glass-panel rounded-3xl border border-white/10 p-8 md:p-10 relative overflow-hidden shadow-2xl">
            <!-- Glow background -->
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-hypr-cyan/5 blur-[80px] -z-10 rounded-full"></div>

            <form action="/blog/search" method="post" class="max-w-3xl mx-auto relative z-10">
                <div class="flex flex-col sm:flex-row gap-4">
                    <div class="flex-grow">
                        <input type="text"
                               class="w-full px-6 py-4 bg-black/60 border border-white/10 rounded-2xl shadow-inner focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all text-lg text-white placeholder:text-slate-600"
                               name="query"
                               value="{{ search_query }}"
                               placeholder="Search parameters...">
                    </div>
                    <div>
                        <button type="submit"
                                class="w-full sm:w-auto glow-btn px-10 py-4 bg-hypr-dark text-white font-bold rounded-2xl shadow-[0_0_20px_rgba(0,168,244,0.2)] hover:scale-105 transition-all text-lg border border-hypr-cyan/50">
                            Query
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Search Results -->
    {% if search_query %}
        {% if results %}
            <div class="space-y-8">
                <div class="flex justify-between items-center glass-panel px-6 py-4 rounded-2xl border border-white/10 text-sm font-mono text-slate-400">
                    <p>
                        Discovered <span class="text-hypr-cyan font-bold text-lg">{{ results | length }}</span> artifact(s)
                    </p>
                    {% if num_pages > 1 %}
                    <p>Page {{ page }} / {{ num_pages }}</p>
                    {% endif %}
                </div>

                <div class="grid gap-8">
                    {% for post in results %}
                    <article class="group relative glass-panel rounded-3xl border border-white/5 hover:border-hypr-cyan/30 overflow-hidden hover:-translate-y-1 transition-all duration-500 p-8 shadow-xl">
                        <div class="absolute -inset-1 bg-gradient-to-r from-hypr-cyan to-hypr-teal opacity-0 group-hover:opacity-10 blur-xl transition-opacity duration-500 rounded-3xl -z-10"></div>
                        
                        <header class="mb-4">
                            <h2 class="text-3xl font-bold mb-3">
                                <a href="/blog/{{ post.seq_id }}" class="text-white hover:text-hypr-cyan transition-colors focus:outline-none before:absolute before:inset-0">
                                    {{ post.title }}
                                </a>
                            </h2>
                            <div class="inline-flex items-center px-3 py-1 rounded-md text-xs font-mono bg-white/5 text-hypr-cyan border border-white/10">
                                Match: {{ (post.rank * 100) | round(precision=1) }}%
                            </div>
                        </header>

                        <!-- Highlighted excerpt -->
                        <div class="text-slate-400 text-lg mb-6 leading-relaxed search-content line-clamp-3">
                            {% if post.headline %}
                                <div class="search-headline">{{ post.headline | safe }}</div>
                            {% elif post.excerpt %}
                                <div>{{ post.excerpt }}</div>
                            {% endif %}
                        </div>

                        <div class="flex items-center justify-between pt-6 border-t border-white/5">
                            {% set summary = false %}
                            {% for reaction_summary in reaction_summaries %}
                                {% if reaction_summary.post_id == post.id %}
                                    {% set summary = reaction_summary %}
                                {% endif %}
                            {% endfor %}
                            
                            <div class="text-sm font-mono text-slate-500">
                                {% if summary and summary.total_reactions > 0 %}
                                    <span class="flex items-center gap-2">
                                        <span class="text-hypr-cyan">~></span> {{summary.total_reactions}} Reaction{% if summary.total_reactions != 1 %}s{% endif %}
                                    </span>
                                {% else %}
                                    <span class="flex items-center gap-2"><span class="text-slate-600">~></span> No reactions</span>
                                {% endif %}
                            </div>

                            <a href="/blog/{{ post.seq_id }}" class="text-hypr-cyan font-semibold text-sm tracking-wider uppercase flex items-center gap-2 group-hover:gap-3 transition-all">
                                Access <span aria-hidden="true">&rarr;</span>
                            </a>
                        </div>
                    </article>
                    {% endfor %}
                </div>

                <!-- Pagination -->
                {% if num_pages > 1 %}
                <div class="mt-12 flex justify-center">
                    <nav class="flex items-center gap-2 glass-panel rounded-full p-2 border-white/10">
                        {% if page > 1 %}
                        <a href="/blog/search?query={{ search_query }}&page={{ page - 1 }}&page_size={{ page_size }}" class="px-5 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 rounded-full transition-colors">
                            Prev
                        </a>
                        {% endif %}

                        {% for page_num in range(start=1, end=num_pages + 1) %}
                            {% if page_num == page %}
                            <span class="px-5 py-2 text-sm font-bold text-hypr-dark bg-hypr-cyan rounded-full shadow-[0_0_10px_rgba(0,168,244,0.5)]">
                                {{ page_num }}
                            </span>
                            {% else %}
                            <a href="/blog/search?query={{ search_query }}&page={{ page_num }}&page_size={{ page_size }}" class="px-5 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 rounded-full transition-colors">
                                {{ page_num }}
                            </a>
                            {% endif %}
                        {% endfor %}

                        {% if page < num_pages %}
                        <a href="/blog/search?query={{ search_query }}&page={{ page + 1 }}&page_size={{ page_size }}" class="px-5 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 rounded-full transition-colors">
                            Next
                        </a>
                        {% endif %}
                    </nav>
                </div>
                {% endif %}
            </div>
        {% else %}
            <div class="glass-panel border-white/10 rounded-3xl p-16 text-center shadow-xl relative overflow-hidden">
                <div class="absolute inset-0 bg-red-500/5 -z-10"></div>
                <div class="text-hypr-cyan text-5xl mb-6 animate-pulse">!</div>
                <h4 class="text-2xl font-black text-white mb-2 tracking-tighter">Null Result</h4>
                <p class="text-slate-400 font-mono">No sequence found for parameter: <span class="text-hypr-cyan">"{{ search_query }}"</span></p>
            </div>
        {% endif %}
    {% else %}
        <div class="glass-panel border-white/10 rounded-3xl p-10 md:p-12 relative overflow-hidden">
            <div class="absolute -right-20 -top-20 w-64 h-64 bg-hypr-teal/10 blur-[80px] -z-10 rounded-full"></div>
            <h4 class="text-2xl font-black text-white mb-4 tracking-tighter flex items-center gap-3">
                <span class="text-hypr-cyan">#</span> Query Engine
            </h4>
            <p class="text-slate-300 text-lg mb-6 leading-relaxed max-w-2xl">Initialize search to scan through the central archive. Capabilities include:</p>
            <ul class="space-y-3 font-mono text-sm text-slate-400">
                <li class="flex items-center gap-3"><span class="text-hypr-cyan">>></span> Full-text pattern matching</li>
                <li class="flex items-center gap-3"><span class="text-hypr-cyan">>></span> Heuristic relevance sorting</li>
                <li class="flex items-center gap-3"><span class="text-hypr-cyan">>></span> Syntax highlighting</li>
            </ul>
        </div>
    {% endif %}

    <!-- Tag Cloud -->
    {% if all_tags %}
    <div class="mt-16 glass-panel rounded-3xl border border-white/10 overflow-hidden">
        <div class="px-8 py-5 border-b border-white/5 bg-white/[0.02]">
            <h5 class="font-bold text-white tracking-widest uppercase text-sm">System Registry Tags</h5>
        </div>
        <div class="p-8 flex flex-wrap gap-3">
            {% for tag in all_tags %}
            <a href="/blog/tag/{{ tag.slug }}"
               class="text-sm font-mono px-4 py-2 rounded-lg text-white border border-white/10 hover:border-white/40 transition-all backdrop-blur-md hover:scale-105"
               style="background-color: {{ tag.color }}40;">
                #{{ tag.name }}
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>

<style>
.search-headline mark {
    background-color: rgba(0, 168, 244, 0.2);
    color: #00e5d0;
    padding: 0.125rem 0.375rem;
    border-radius: 0.375rem;
    font-weight: bold;
    box-shadow: 0 0 10px rgba(0, 168, 244, 0.3);
}
</style>
{% endblock %}