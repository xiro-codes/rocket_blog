{% extends "base" %}

{% block content %}
<div class="max-w-4xl mx-auto py-8">
	<header class="mb-8 text-center">
		<h1 class="text-3xl font-bold text-gray-900 dark:text-white tracking-tight">Create Article</h1>
	</header>

	<hr class="border-gray-200 dark:border-gray-700 my-6">

	<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 md:p-8">
		<form action="{{form_url}}" method="post" enctype="multipart/form-data" class="space-y-6">
			<h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-6 border-b border-gray-100 dark:border-gray-700 pb-4">New Post Configuration</h3>
			
			<div class="space-y-2">
				<label for="title" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Title:</label>
				<div class="flex gap-2">
					<input type="text" name="title" id="title" class="flex-1 px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" placeholder="Enter post title..." />
					{% if ai_available %}
					<button type="button" id="generate-content-btn" class="bg-emerald-500 hover:bg-emerald-600 text-white px-4 py-2 rounded-md font-medium transition shadow-sm whitespace-nowrap">✨ Generate</button>
					{% endif %}
				</div>
			</div>
			
			{% if ai_available %}
			<div id="ai-prompt-section" style="display: none;" class="bg-indigo-50 dark:bg-indigo-900/20 p-4 rounded-lg border border-indigo-100 dark:border-indigo-800">
				<label for="ai-prompt" class="block text-sm font-medium text-indigo-900 dark:text-indigo-300 mb-1">AI Prompt (Optional):</label>
				<input type="text" id="ai-prompt" class="w-full px-4 py-2 bg-white dark:bg-gray-900 border border-indigo-200 dark:border-indigo-700 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition" placeholder="Additional context for AI generation..." />
				<p class="mt-1 text-xs text-indigo-600 dark:text-indigo-400">Provide additional context to guide AI content generation</p>
			</div>
			{% endif %}
			
			<div class="space-y-2">
				<label for="excerpt" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Excerpt:</label>
				<div class="flex flex-col sm:flex-row gap-2">
					<textarea name="excerpt" id="excerpt" rows="3" class="flex-1 px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition resize-y" 
				          placeholder="Brief summary of the post (optional - will be auto-generated if left empty)"></textarea>
					{% if ai_available %}
					<button type="button" id="generate-excerpt-btn" class="sm:self-start bg-white dark:bg-gray-800 border border-emerald-500 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 px-4 py-2 rounded-md font-medium transition shadow-sm whitespace-nowrap">✨ Generate Excerpt</button>
					{% endif %}
				</div>
				<p class="text-xs text-gray-500 dark:text-gray-400">Optional short summary that will appear in post listings. If left empty, it will be auto-generated from the content.</p>
			</div>
			
			<div class="space-y-2">
				<label for="text" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Content:</label>
				<div class="rounded-md shadow-sm bg-white dark:bg-gray-900">
					<textarea name="text" id="text" rows="12" class="w-full" placeholder="Write your post content here..."></textarea>
				</div>
			</div>
			
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-50 dark:bg-gray-800/50 p-4 rounded-lg border border-gray-200 dark:border-gray-700 relative">
				<div class="space-y-2">
					<label for="file" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Media File:</label>
					<input type="file" name="file" id="file" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm text-sm" accept="video/*" />
				</div>
				
				<div class="hidden md:flex absolute inset-y-0 left-1/2 items-center justify-center -translate-x-1/2">
					<span class="bg-gray-200 dark:bg-gray-700 text-gray-500 dark:text-gray-400 text-xs font-bold px-2 py-1 rounded-full uppercase">OR</span>
				</div>
				<div class="md:hidden flex justify-center py-2">
					<span class="bg-gray-200 dark:bg-gray-700 text-gray-500 dark:text-gray-400 text-xs font-bold px-2 py-1 rounded-full uppercase">OR</span>
				</div>
				
				<div class="space-y-2">
					<label for="youtube_url" class="block text-sm font-medium text-gray-700 dark:text-gray-300">YouTube URL:</label>
					<input type="url" name="youtube_url" id="youtube_url" class="w-full px-4 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" 
					       placeholder="https://www.youtube.com/watch?v=..." />
					<p class="text-xs text-gray-500 dark:text-gray-400">Provide a YouTube URL to download the video. The download will happen in the background.</p>
				</div>
			</div>
			
			<div class="space-y-2">
				<label for="tags" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Tags (comma-separated):</label>
				<div class="flex flex-col sm:flex-row gap-2">
					<input type="text" class="flex-1 px-4 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition" name="tags" id="tags" placeholder="e.g. rust, web development, tutorial">
					{% if ai_available %}
					<button type="button" id="generate-tags-btn" class="sm:self-start bg-white dark:bg-gray-800 border border-emerald-500 text-emerald-600 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 px-4 py-2 rounded-md font-medium transition shadow-sm whitespace-nowrap">✨ Generate Tags</button>
					{% endif %}
				</div>
				<p class="text-xs text-gray-500 dark:text-gray-400">Separate multiple tags with commas</p>
			</div>
			
			<div class="flex flex-col sm:flex-row justify-center gap-4 pt-6 border-t border-gray-100 dark:border-gray-700 mt-8">
				<button type="submit" name="action" value="draft" class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-medium py-2.5 px-6 rounded-md transition shadow-sm">Save as Draft</button>
				<button type="submit" name="action" value="publish" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-8 rounded-md transition shadow-sm shadow-blue-500/30">Publish Post</button>
			</div>
		</form>
	</div>
</div>

{% if flash %}
<div class="fixed bottom-4 right-4 bg-amber-100 border-l-4 border-amber-500 text-amber-800 p-4 rounded shadow-lg transition-opacity duration-300 z-50">
	<div class="flex items-center">
		<svg class="h-5 w-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
			<path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
		</svg>
		<p class="font-medium">{{ flash[1] }}</p>
	</div>
</div>
{% endif %}

{% endblock %}

{% block script %}
<script>
document.addEventListener('DOMContentLoaded', function() {
	const easyMDE = new EasyMDE({
		element: document.getElementById('text'),
		spellChecker: false,
		autofocus: false,
		placeholder: 'Write your post content here in Markdown...',
		toolbar: [
			'bold', 'italic', 'heading', '|',
			'quote', 'unordered-list', 'ordered-list', '|',
			'link', 'image', '|',
			'code', 'table', '|',
			'preview', 'side-by-side', 'fullscreen', '|',
			'guide'
		],
		status: ['autosave', 'lines', 'words', 'cursor'],
		renderingConfig: {
			singleLineBreaks: false,
			codeSyntaxHighlighting: true,
		},
		insertTexts: {
			horizontalRule: ["", "\n\n-----\n\n"],
			image: ["![](http://", ")"],
			link: ["[", "](http://)"],
			table: ["", "\n\n| Column 1 | Column 2 | Column 3 |\n| -------- | -------- | -------- |\n| Text     | Text     | Text     |\n\n"],
		}
	});

	// Handle file upload vs YouTube URL mutual exclusion
	const fileInput = document.getElementById('file');
	const youtubeInput = document.getElementById('youtube_url');

	if (fileInput && youtubeInput) {
		fileInput.addEventListener('change', function() {
			if (this.files && this.files.length > 0) {
				youtubeInput.disabled = true;
				youtubeInput.value = '';
				youtubeInput.placeholder = 'File upload selected - clear file to enable YouTube URL';
				youtubeInput.classList.add('opacity-50', 'bg-gray-100');
			} else {
				youtubeInput.disabled = false;
				youtubeInput.placeholder = 'https://www.youtube.com/watch?v=...';
				youtubeInput.classList.remove('opacity-50', 'bg-gray-100');
			}
		});

		youtubeInput.addEventListener('input', function() {
			if (this.value.trim()) {
				fileInput.disabled = true;
				fileInput.classList.add('opacity-50', 'cursor-not-allowed');
			} else {
				fileInput.disabled = false;
				fileInput.classList.remove('opacity-50', 'cursor-not-allowed');
			}
		});
	}

	// AI Generation functionality (only if any AI service is available)
	{% if ai_available %}
	const titleInput = document.getElementById('title');
	const promptInput = document.getElementById('ai-prompt');
	const promptSection = document.getElementById('ai-prompt-section');
	const generateContentBtn = document.getElementById('generate-content-btn');
	const generateExcerptBtn = document.getElementById('generate-excerpt-btn');
	const generateTagsBtn = document.getElementById('generate-tags-btn');
	const excerptTextarea = document.getElementById('excerpt');
	const tagsInput = document.getElementById('tags');

	// Show/hide AI prompt section when title is entered
	if (titleInput && promptSection) {
		titleInput.addEventListener('input', function() {
			if (this.value.trim()) {
				promptSection.style.display = 'block';
			} else {
				promptSection.style.display = 'none';
			}
		});
	}

	// Generate content with AI
	if (generateContentBtn) {
		generateContentBtn.addEventListener('click', async function() {
			const title = titleInput.value.trim();
			if (!title) {
				alert('Please enter a title first');
				return;
			}

			const prompt = promptInput ? promptInput.value.trim() : null;
			this.disabled = true;
			this.textContent = '🤖 Generating...';
			this.classList.add('opacity-75', 'cursor-wait');

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						type: 'content',
						title: title,
						prompt: prompt
					})
				});

				const data = await response.json();
				
				if (data.success) {
					easyMDE.value(data.content);
				} else {
					alert('Error generating content: ' + (data.error || 'Unknown error'));
				}
			} catch (error) {
				alert('Error generating content: ' + error.message);
			} finally {
				this.disabled = false;
				this.textContent = '✨ Generate';
				this.classList.remove('opacity-75', 'cursor-wait');
			}
		});
	}

	// Generate excerpt with AI
	if (generateExcerptBtn) {
		generateExcerptBtn.addEventListener('click', async function() {
			const content = easyMDE.value();
			if (!content.trim()) {
				alert('Please write some content first');
				return;
			}

			this.disabled = true;
			this.textContent = '🤖 Generating...';
			this.classList.add('opacity-75', 'cursor-wait');

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						type: 'excerpt',
						content: content
					})
				});

				const data = await response.json();
				
				if (data.success) {
					excerptTextarea.value = data.excerpt;
				} else {
					alert('Error generating excerpt: ' + (data.error || 'Unknown error'));
				}
			} catch (error) {
				alert('Error generating excerpt: ' + error.message);
			} finally {
				this.disabled = false;
				this.textContent = '✨ Generate Excerpt';
				this.classList.remove('opacity-75', 'cursor-wait');
			}
		});
	}

	// Generate tags with AI
	if (generateTagsBtn) {
		generateTagsBtn.addEventListener('click', async function() {
			const title = titleInput.value.trim();
			const content = easyMDE.value();
			
			if (!title && !content.trim()) {
				alert('Please enter a title or write some content first');
				return;
			}

			this.disabled = true;
			this.textContent = '🤖 Generating...';
			this.classList.add('opacity-75', 'cursor-wait');

			try {
				const response = await fetch('/blog/generate-content', {
					method: 'POST',
					headers: {
						'Content-Type': 'application/json',
					},
					body: JSON.stringify({
						type: 'tags',
						title: title,
						content: content
					})
				});

				const data = await response.json();
				
				if (data.success) {
					tagsInput.value = data.tags;
				} else {
					alert('Error generating tags: ' + (data.error || 'Unknown error'));
				}
			} catch (error) {
				alert('Error generating tags: ' + error.message);
			} finally {
				this.disabled = false;
				this.textContent = '✨ Generate Tags';
				this.classList.remove('opacity-75', 'cursor-wait');
			}
		});
	}
	{% endif %}
});
</script>
{% endblock %}