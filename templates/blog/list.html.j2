{% extends "base" %}

{% block content %}
<div class="max-w-6xl mx-auto">
	<!-- Hero Section -->
	<div class="flex flex-col items-center justify-center text-center py-20 animate-fade-in-up">
		<h1 class="text-6xl md:text-8xl font-black tracking-tighter text-white mb-6">
			Discover <br/>
			<span class="text-gradient">The Future.</span>
		</h1>
		<p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 font-light">
			Insights, updates, and deep dives into technology, development, and more. Explore the latest articles below.
		</p>
	</div>

	{% if flash %}
	<div class="mb-10 p-4 rounded-2xl glass-panel border-{{ 'hypr-teal' if flash[0] == 'success' else 'red-500' }}/50 text-white flex items-center gap-3 animate-fade-in-up">
		<span class="text-{{ 'hypr-teal' if flash[0] == 'success' else 'red-500' }}">&bull;</span>
		{{ flash[1] }}
	</div>
	{% endif %}

	<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 animate-fade-in-up" style="animation-delay: 0.2s;">
		
		<!-- Main Posts Grid -->
		<div class="lg:col-span-8 space-y-8">
			{% for post in posts %}
			<article class="group relative glass-panel rounded-3xl p-8 hover:-translate-y-1 hover:shadow-[0_10px_40px_rgba(0,168,244,0.15)] transition-all duration-500 border-white/5 hover:border-hypr-cyan/30 overflow-hidden">
				<!-- Hover Glow Effect -->
				<div class="absolute -inset-1 bg-gradient-to-r from-hypr-cyan to-hypr-teal opacity-0 group-hover:opacity-10 blur-xl transition-opacity duration-500 rounded-3xl -z-10"></div>
				
				<div class="relative z-10">
					<div class="flex items-center gap-3 mb-4">
						<h2 class="text-3xl font-bold text-white group-hover:text-hypr-cyan transition-colors line-clamp-2">
							<a href="/blog/{{post.seq_id}}" class="focus:outline-none before:absolute before:inset-0">{{post.title}}</a>
						</h2>
						{% if post.draft and token %}
						<span class="px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-400 text-xs font-bold tracking-widest uppercase shadow-[0_0_10px_rgba(245,158,11,0.2)]">Draft</span>
						{% endif %}
					</div>
					
					{% if post.excerpt %}
					<p class="text-slate-400 text-lg mb-8 leading-relaxed line-clamp-3">{{post.excerpt}}</p>
					{% endif %}

					{% set summary = false %}
					{% for reaction_summary in reaction_summaries %}
						{% if reaction_summary.post_id == post.id %}
							{% set summary = reaction_summary %}
						{% endif %}
					{% endfor %}
					
					<div class="flex items-center justify-between pt-6 border-t border-white/5">
						<div class="text-sm font-mono text-slate-500">
							{% if summary and summary.total_reactions > 0 %}
								<span class="flex items-center gap-2">
									<span class="text-hypr-cyan">~></span> {{summary.total_reactions}} Reaction{% if summary.total_reactions != 1 %}s{% endif %}
								</span>
							{% else %}
								<span class="flex items-center gap-2"><span class="text-slate-600">~></span> No reactions</span>
							{% endif %}
						</div>
						<div class="text-hypr-cyan font-semibold text-sm tracking-wider uppercase flex items-center gap-2 group-hover:gap-3 transition-all">
							Read <span aria-hidden="true">&rarr;</span>
						</div>
					</div>
				</div>
			</article>
			{% endfor %}
			
			{% if not posts %}
			<div class="glass-panel rounded-3xl p-16 text-center border-dashed border-white/20">
				<div class="text-hypr-cyan text-4xl mb-4">∅</div>
				<p class="text-slate-400 text-lg">No records found in the database.</p>
			</div>
			{% endif %}
		</div>
		
		<!-- Sidebar -->
		<div class="lg:col-span-4">
			{% if all_tags %}
			<div class="sticky top-24 glass-panel rounded-3xl overflow-hidden border border-white/10">
				<div class="px-6 py-5 border-b border-white/5 bg-white/[0.02]">
					<h3 class="font-bold text-white tracking-widest uppercase text-sm">System Tags</h3>
				</div>
				<div class="p-6 flex flex-wrap gap-2">
					{% for tag in all_tags %}
					<a href="/blog/tag/{{ tag.slug }}"
					   class="text-xs font-mono px-3 py-1.5 rounded-md text-white border border-white/10 hover:border-white/40 transition-colors backdrop-blur-md"
					   style="background-color: {{ tag.color }}40;">
						#{{ tag.name }}
					</a>
					{% endfor %}
				</div>
			</div>
			{% endif %}
		</div>
	</div>

	<!-- Pagination -->
	<div class="mt-16 flex justify-center animate-fade-in-up" style="animation-delay: 0.4s;">
		<nav class="flex items-center gap-1 glass-panel rounded-full p-1 border-white/10">
			{% if page == 1 %}
			<button class="px-5 py-2 text-sm font-medium text-slate-600 rounded-full cursor-not-allowed" disabled>Prev</button>
			{% else %}
			<a class="px-5 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 rounded-full transition-colors" href="?page={{page -1}}&page_size={{page_size}}">Prev</a>
			{%endif%}
			
			<span class="px-4 py-2 text-sm font-mono text-hypr-cyan font-bold">
				{{page}} <span class="text-slate-500 font-normal">/</span> {{num_pages if num_pages > 0 else 1}}
			</span>
			
			{% if page == num_pages or num_pages == 0 %}
			<button class="px-5 py-2 text-sm font-medium text-slate-600 rounded-full cursor-not-allowed" disabled>Next</button>
			{%else%}
			<a class="px-5 py-2 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/10 rounded-full transition-colors" href="?page={{page +1}}&page_size={{page_size}}">Next</a>
			{%endif%}
		</nav>
	</div>
</div>
{% endblock %}