{% extends "base" %}

{% block content %}
<div class="terminal-header"></div>
<div class="d-flex flex-column align-items-center justify-content-center">
	<h1 class="terminal-prompt">Articles</h1>
	{% if flash %}
	<h3 class="btn-{{ flash[0] }} btn disabled">
		{{ flash[1] }}
	</h3>
	{% endif %}

	{% if token %}
	<div class="btn-group mb-3 flex-wrap">
		{% if is_admin %}
		<a class="btn btn-primary" href="/blog/create">[CREATE POST]</a>
		{% endif %}
		<a class="btn btn-success" href="/blog/search">[SEARCH]</a>
		{% if is_admin %}
		<a class="btn btn-secondary" href="/settings">[SETTINGS]</a>
		{% endif %}
		<a class="btn btn-primary" href="/auth/logout">[LOGOUT]</a>
		<button id="install-btn" class="btn btn-info" onclick="installPWA()" style="display: none;">[INSTALL APP]</button>
	</div>
	{% else %}
	<div class="mb-3">
		<a class="btn btn-success" href="/blog/search">[SEARCH POSTS]</a>
		{% if not has_accounts %}
		<a class="btn btn-warning" href="/auth/create-admin">[CREATE ADMIN ACCOUNT]</a>
		{% else %}
		<a class="btn btn-primary" href="/auth/">[LOGIN]</a>
		{% endif %}
		<button id="install-btn" class="btn btn-info" onclick="installPWA()" style="display: none;">[INSTALL APP]</button>
	</div>
	{% if not has_accounts %}
	<div class="alert alert-info text-center mx-5">
		<h4>🚀 Welcome to your new blog!</h4>
		<p>No admin account exists yet. Click the "CREATE ADMIN ACCOUNT" button above to get started.</p>
	</div>
	{% endif %}
	{% endif %}
</div>

<hr class="terminal-divider">

<div class="row">
	<div class="col-12 col-lg-8">
		<div class="mx-2 mx-md-5 my-2">
			{% for post in posts %}
			<li class="list-group-item">
				{% if post.draft and token %}
				<span class="badge bg-warning text-dark ms-2">DRAFT</span>
				{% endif %}
			</li>
			<div class="card mb-3 terminal-post">
				<div class="card-body">
					<h5 class="card-title">
						<span class="terminal-prompt"></span>
						<a class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover text-decoration-none"
						   href="/blog/{{post.seq_id}}">{{post.title}}</a>
						{% if post.draft and token %}
						<span class="badge bg-warning text-dark ms-2">[DRAFT]</span>
						{% endif %}
					</h5>
					{% if post.excerpt %}
					<p class="card-text text-muted">{{post.excerpt}}</p>
					{% endif %}
					
					<!-- Reaction counts -->
					{% set_global summary = false %}
					{% for reaction_summary in reaction_summaries %}
						{% if reaction_summary.post_id == post.id %}
							{% set_global summary = reaction_summary %}
						{% endif %}
					{% endfor %}
					{% if summary %}
					<div class="reaction-summary mb-2">
						<small class="text-muted">
							{% if summary.total_reactions > 0 %}
							<span class="reactions-count">
								👍 {{summary.total_reactions}} reaction{% if summary.total_reactions != 1 %}s{% endif %}
							</span>
							{% else %}
							<span class="reactions-count">No reactions yet</span>
							{% endif %}
						</small>
					</div>
					{% endif %}
					
					<a href="/blog/{{post.seq_id}}" class="btn btn-outline-primary btn-sm">[READ MORE]</a>
				</div>
			</div>
			{% endfor %}
		</div>
	</div>
	<div class="col-12 col-lg-4">
		{% if all_tags %}
		<div class="card">
			<div class="card-header">
				<h5>[ TAGS ]</h5>
			</div>
			<div class="card-body">
				{% for tag in all_tags %}
				<a href="/blog/tag/{{ tag.slug }}" 
				   class="badge text-decoration-none me-1 mb-1"
				   style="background-color: {{ tag.color }};">
					{{ tag.name }}
				</a>
				{% endfor %}
			</div>
		</div>
		{% endif %}
	</div>
</div>

<hr class="terminal-divider">

<div class="d-flex justify-content-center m-2">
	<footer class="btn-group align-items-center flex-wrap">
		{% if page == 1 %}
		<button class="btn btn-secondary" disabled>[PREV]</button>
		{% else %}
		<a class="btn btn-primary" href="?page={{page -1}}&page_size={{page_size}}">[PREV]</a>
		{% endif %}
		<button class="btn btn-secondary" disabled>
			PAGE {{page}}
		</button>
		{% if page == num_pages %}
		<button class="btn btn-secondary" disabled>[NEXT]</button>
		{% else %}
		<a class="btn btn-primary" href="?page={{page +1}}&page_size={{page_size}}">[NEXT]</a>
		{% endif %}
	</footer>
</div>
{% endblock %}
{% block script %}
{% endblock %}
