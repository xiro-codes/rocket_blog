{% extends "base" %}

{% block content %}
<div class="max-w-4xl mx-auto py-8">
	<div class="flex flex-col md:flex-row justify-between items-center mb-8">
		<h1 class="text-4xl font-bold text-gray-900 dark:text-white tracking-tight">Articles</h1>
		
		<div class="flex flex-wrap gap-2 mt-4 md:mt-0">
			{%if token %}
				{%if is_admin %}
				<a class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition" href="/blog/create">Create Post</a>
				<a class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-medium py-2 px-4 rounded-md transition" href="/settings">Settings</a>
				{%endif%}
				<a class="bg-indigo-100 dark:bg-indigo-900/50 hover:bg-indigo-200 dark:hover:bg-indigo-800/50 text-indigo-700 dark:text-indigo-300 font-medium py-2 px-4 rounded-md transition border border-indigo-200 dark:border-indigo-800" href="/blog/search">Search</a>
				<a class="bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-800/30 text-red-600 dark:text-red-400 font-medium py-2 px-4 rounded-md transition border border-red-200 dark:border-red-800/50" href="/auth/logout">Logout</a>
			{%else%}
				<a class="bg-indigo-100 dark:bg-indigo-900/50 hover:bg-indigo-200 dark:hover:bg-indigo-800/50 text-indigo-700 dark:text-indigo-300 font-medium py-2 px-4 rounded-md transition border border-indigo-200 dark:border-indigo-800" href="/blog/search">Search Posts</a>
				{% if not has_accounts %}
				<a class="bg-amber-500 hover:bg-amber-600 text-white font-medium py-2 px-4 rounded-md transition" href="/auth/create-admin">Create Admin Account</a>
				{% else %}
				<a class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-md transition" href="/auth/">Login</a>
				{% endif %}
			{%endif%}
			<button id="install-btn" class="bg-emerald-500 hover:bg-emerald-600 text-white font-medium py-2 px-4 rounded-md transition" onclick="installPWA()" style="display: none;">Install App</button>
		</div>
	</div>

	{% if flash %}
	<div class="mb-6 p-4 rounded-md bg-{{ 'green' if flash[0] == 'success' else 'red' }}-50 text-{{ 'green' if flash[0] == 'success' else 'red' }}-800 border border-{{ 'green' if flash[0] == 'success' else 'red' }}-200">
		{{ flash[1] }}
	</div>
	{% endif %}

	{% if not has_accounts and not token %}
	<div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 p-6 rounded-lg mb-8 text-center">
		<h4 class="text-xl font-bold text-blue-800 dark:text-blue-300 mb-2">🚀 Welcome to your new blog!</h4>
		<p class="text-blue-600 dark:text-blue-400">No admin account exists yet. Click the "Create Admin Account" button above to get started.</p>
	</div>
	{% endif %}

	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
		<div class="lg:col-span-2 space-y-6">
			{% for post in posts %}
			<article class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden hover:shadow-md transition">
				<div class="p-6">
					<div class="flex items-center gap-2 mb-2">
						<h2 class="text-2xl font-bold">
							<a class="text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition" href="/blog/{{post.seq_id}}">{{post.title}}</a>
						</h2>
						{% if post.draft and token %}
						<span class="bg-amber-100 text-amber-800 text-xs font-semibold px-2.5 py-0.5 rounded dark:bg-amber-900/30 dark:text-amber-300 border border-amber-200 dark:border-amber-800">DRAFT</span>
						{% endif %}
					</div>
					
					{% if post.excerpt %}
					<p class="text-gray-600 dark:text-gray-400 mb-4">{{post.excerpt}}</p>
					{% endif %}

					<!-- Reaction counts -->
					{% set summary = false %}
					{% for reaction_summary in reaction_summaries %}
						{% if reaction_summary.post_id == post.id %}
							{% set summary = reaction_summary %}
						{% endif %}
					{% endfor %}
					
					<div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100 dark:border-gray-700">
						<div class="text-sm text-gray-500 dark:text-gray-400">
							{% if summary and summary.total_reactions > 0 %}
								<span class="flex items-center gap-1">
									👍 {{summary.total_reactions}} reaction{% if summary.total_reactions != 1 %}s{% endif %}
								</span>
							{% else %}
								<span>No reactions yet</span>
							{% endif %}
						</div>
						<a href="/blog/{{post.seq_id}}" class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium text-sm flex items-center gap-1">
							Read More <span aria-hidden="true">&rarr;</span>
						</a>
					</div>
				</div>
			</article>
			{% endfor %}
			
			{% if not posts %}
			<div class="text-center py-12 text-gray-500 dark:text-gray-400">
				<p>No posts found.</p>
			</div>
			{% endif %}
		</div>
		
		<div class="lg:col-span-1">
			{% if all_tags %}
			<div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden sticky top-6">
				<div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 bg-gray-50/50 dark:bg-gray-800/50">
					<h3 class="font-bold text-gray-900 dark:text-white">Tags</h3>
				</div>
				<div class="p-6 flex flex-wrap gap-2">
					{% for tag in all_tags %}
					<a href="/blog/tag/{{ tag.slug }}"
					   class="text-xs font-semibold px-2.5 py-1 rounded-full hover:opacity-80 transition text-white shadow-sm"
					   style="background-color: {{ tag.color }};">
						{{ tag.name }}
					</a>
					{% endfor %}
				</div>
			</div>
			{% endif %}
		</div>
	</div>

	<div class="mt-12 flex justify-center">
		<nav class="flex items-center gap-2">
			{% if page == 1 %}
			<button class="px-4 py-2 text-sm font-medium text-gray-400 bg-gray-50 dark:bg-gray-800/50 dark:text-gray-600 border border-gray-200 dark:border-gray-700 rounded-l-md cursor-not-allowed" disabled>Previous</button>
			{% else %}
			<a class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-l-md hover:bg-gray-50 dark:hover:bg-gray-700 transition" href="?page={{page -1}}&page_size={{page_size}}">Previous</a>
			{%endif%}
			
			<span class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800/50 border-y border-gray-200 dark:border-gray-700">
				Page {{page}} {% if num_pages > 0 %}of {{num_pages}}{% endif %}
			</span>
			
			{% if page == num_pages or num_pages == 0 %}
			<button class="px-4 py-2 text-sm font-medium text-gray-400 bg-gray-50 dark:bg-gray-800/50 dark:text-gray-600 border border-gray-200 dark:border-gray-700 rounded-r-md cursor-not-allowed" disabled>Next</button>
			{%else%}
			<a class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-r-md hover:bg-gray-50 dark:hover:bg-gray-700 transition" href="?page={{page +1}}&page_size={{page_size}}">Next</a>
			{%endif%}
		</nav>
	</div>
</div>
{% endblock %}