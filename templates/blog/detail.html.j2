{% extends "base" %}
{% macro render_comment_thread(thread, post_id, level) %}
<div class="comment-thread" style="margin-left: {{ level * 1.5 }}rem; border-left: {{ '2px solid #e5e7eb' if level > 0 else 'none' }}; padding-left: {{ '1rem' if level > 0 else '0' }}; margin-top: 1rem;">
	<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-4 mb-4" data-comment-id="{{ thread.comment.id }}">
		<div class="flex justify-between items-start mb-2">
			<div class="flex-grow">
				<div class="font-semibold text-gray-900 dark:text-white mb-1">
					{{ thread.display_username }}
				</div>
				<div class="text-gray-700 dark:text-gray-300">{{ thread.comment.text }}</div>
			</div>
			<div class="text-right flex flex-col items-end shrink-0 ml-4">
				<div class="text-xs text-gray-500 dark:text-gray-400 mb-2">{{ thread.comment.date_published }}</div>
				<button class="text-blue-600 hover:text-blue-800 dark:text-blue-400 dark:hover:text-blue-300 font-medium text-sm transition"
						hx-on:click="document.getElementById('reply-form-{{ thread.comment.id }}').style.display = 'block'">
					Reply
				</button>
			</div>
		</div>

		<!-- Reply form (initially hidden) -->
		<div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-700" id="reply-form-{{ thread.comment.id }}" style="display: none;">
			<form action="/comment/reply/{{ post_id }}/{{ thread.comment.id }}" method="post" class="flex flex-col gap-3">
				{% if not token %}
				<div>
					<label for="username-{{ thread.comment.id }}" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Name (optional):</label>
					<input type="text" id="username-{{ thread.comment.id }}" name="username" class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" placeholder="Your name..." />
				</div>
				{% endif %}
				<div>
					<label for="text-{{ thread.comment.id }}" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Reply:</label>
					<textarea id="text-{{ thread.comment.id }}" name="text" class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" placeholder="Enter your reply..." required rows="2"></textarea>
				</div>
				<div class="flex gap-2 justify-end mt-1">
					<button class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-medium py-1.5 px-4 rounded-md transition text-sm cancel-reply" type="button"
							hx-on:click="document.getElementById('reply-form-{{ thread.comment.id }}').style.display = 'none'; this.closest('form').reset()">Cancel</button>
					<button class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-1.5 px-4 rounded-md transition text-sm" type="submit">Post Reply</button>
				</div>
			</form>
		</div>
	</div>

	<!-- Render child comments recursively -->
	{% for reply in thread.replies %}
		{{ render_comment_thread(thread=reply, post_id=post_id, level=level + 1) }}
	{% endfor %}
</div>
{% endmacro %}
{% block content %}
<!-- Schema.org structured data for blog post -->
{% if post %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ post.title | escape }}",
  "description": "{% if post.excerpt %}{{ post.excerpt | escape }}{% else %}{{ post.text | truncate(160) | escape }}{% endif %}",
  "author": {
    "@type": "Person",
    "name": "{{ username }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Rocket Blog"
  },
  "datePublished": "{{ post.date_published }}",
  "dateModified": "{{ post.date_published }}",
  "url": "/blog/{{ post.seq_id }}",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "/blog/{{ post.seq_id }}"
  }{% if tags %},
  "keywords": [{% for tag in tags %}"{{ tag.name | escape }}"{% if not loop.last %},{% endif %}{% endfor %}]{% endif %}
}
</script>
{% endif %}

{% if post %}
<article class="max-w-4xl mx-auto py-8">
	<header class="mb-10 text-center">
		<h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-4">{{post.title}}</h1>
		
		{% if post.draft and token %}
		<div class="inline-flex items-center gap-2 px-4 py-2 bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300 rounded-md mb-4 border border-amber-200 dark:border-amber-800 font-medium">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
				<path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
			</svg>
			[DRAFT POST] - This post is not yet published
		</div>
		{% endif %}
		
		<div class="text-lg text-gray-600 dark:text-gray-400 mb-6 flex items-center justify-center gap-2">
			<span>by <span class="font-semibold text-gray-900 dark:text-white">{{username}}</span></span>
			<span>&bull;</span>
			<time>{{post.date_published}}</time>
		</div>
		
		{% if tags %}
		<div class="flex flex-wrap justify-center gap-2 mb-8">
			{% for tag in tags %}
			<a href="/blog/tag/{{ tag.slug }}" class="text-xs font-semibold px-3 py-1 rounded-full text-white shadow-sm hover:opacity-80 transition" style="background-color: {{ tag.color }}!important;">
				{{ tag.name }}
			</a>
			{% endfor %}
		</div>
		{% endif %}

		<div class="flex flex-wrap justify-center gap-2 mb-4">
			<a class="bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-800 dark:text-gray-200 font-medium py-2 px-4 rounded-md transition" href="/blog">Back to Posts</a>
			<a class="bg-indigo-100 dark:bg-indigo-900/50 hover:bg-indigo-200 dark:hover:bg-indigo-800/50 text-indigo-700 dark:text-indigo-300 font-medium py-2 px-4 rounded-md transition border border-indigo-200 dark:border-indigo-800" href="/blog/search">Search</a>
		</div>
		
		{%if is_admin %}
		<div class="flex flex-wrap justify-center gap-2 mt-4 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-lg border border-gray-200 dark:border-gray-700 inline-flex">
			{% if post.draft %}
			<a class="bg-emerald-500 hover:bg-emerald-600 text-white font-medium py-1.5 px-3 rounded-md transition text-sm" href="{{post.seq_id}}/publish">Publish</a>
			{% endif %}
			<a class="bg-amber-500 hover:bg-amber-600 text-white font-medium py-1.5 px-3 rounded-md transition text-sm" href="{{post.seq_id}}/edit">Edit</a>
			<a class="bg-red-600 hover:bg-red-700 text-white font-medium py-1.5 px-3 rounded-md transition text-sm" href="{{post.seq_id}}/delete">Delete</a>
		</div>
		{%endif%}
	</header>

	{%if post.path%}
	<div class="my-8 flex justify-center bg-black rounded-xl overflow-hidden shadow-lg border border-gray-800">
		<video class="w-full max-h-[600px] object-contain" src="{{post.seq_id}}/video" controls autoplay></video>
	</div>
	{%endif%}

	<div class="prose prose-lg dark:prose-invert max-w-none mb-12 markdown-body">
		{{post.text | safe}}
	</div>

	<hr class="border-gray-200 dark:border-gray-700 my-8">

	<!-- Reaction Section -->
	<section class="mb-12">
		<h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Reactions</h3>
		<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-6 border border-gray-200 dark:border-gray-700" data-post-id="{{post.seq_id}}">
			<div class="flex flex-wrap gap-3 mb-4">
				{% for reaction_type in reaction_types %}
				<button class="inline-flex items-center gap-2 px-4 py-2 rounded-full border transition-all duration-200 {% if reaction_summary.user_reaction == reaction_type.type %}bg-blue-100 dark:bg-blue-900/40 border-blue-300 dark:border-blue-700 text-blue-800 dark:text-blue-300 shadow-sm{% else %}bg-white dark:bg-gray-800 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700{% endif %}"
						title="{{reaction_type.title}}"
						hx-post="{% if reaction_summary.user_reaction == reaction_type.type %}/blog/{{post.seq_id}}/react{% else %}/blog/{{post.seq_id}}/react/{{reaction_type.type}}{% endif %}"
						hx-swap="none"
						hx-on::after-request="location.reload()">
					<span class="text-xl">{{reaction_type.emoji}}</span>
					<span class="font-medium">
						{% set found_count = 0 %}
						{% for reaction in reaction_summary.reactions %}
							{% if reaction.reaction_type == reaction_type.type %}
								{{reaction.count}}
								{% set found_count = reaction.count %}
							{% endif %}
						{% endfor %}
						{% if found_count == 0 %}0{% endif %}
					</span>
				</button>
				{% endfor %}
			</div>
			<div class="text-sm font-medium text-gray-500 dark:text-gray-400">
				Total reactions: <span>{{reaction_summary.total_reactions}}</span>
			</div>
		</div>
	</section>

	<hr class="border-gray-200 dark:border-gray-700 my-8">

	<!-- Comments Section -->
	<section class="mb-12">
		<h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Comments</h3>
		
		<div class="bg-gray-50 dark:bg-gray-800/50 rounded-xl p-6 border border-gray-200 dark:border-gray-700 mb-8">
			<h4 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Leave a Comment</h4>
			<form action="/comment/create/{{post.id}}" method="post" class="flex flex-col gap-4">
				{% if not token %}
				<div>
					<label for="username" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Name (optional):</label>
					<input type="text" id="username" name="username" class="w-full px-4 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500" placeholder="Your name..." />
				</div>
				{% endif %}
				<div>
					<label for="text" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Your Comment:</label>
					<textarea required id="text" name="text" class="w-full px-4 py-2 bg-white dark:bg-gray-900 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 min-h-[100px]" placeholder="Share your thoughts..."></textarea>
				</div>
				<div class="flex justify-end">
					<button class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-6 rounded-md transition shadow-sm" type="submit">Post Comment</button>
				</div>
			</form>
		</div>

		<div class="space-y-4">
			{% if comments %}
				{% for thread in comments %}
					{{ render_comment_thread(thread=thread, post_id=post.id, level=0) }}
				{% endfor %}
			{% else %}
				<p class="text-gray-500 dark:text-gray-400 italic text-center py-8">No comments yet. Be the first to share your thoughts!</p>
			{% endif %}
		</div>
	</section>

	<hr class="border-gray-200 dark:border-gray-700 my-8">

	<!-- Post Navigation -->
	<nav class="flex flex-col sm:flex-row items-center justify-between gap-4 py-4">
		{%if token%}
			{% if post.seq_id == min_post %}
			<button class="px-6 py-3 text-sm font-medium text-gray-400 bg-gray-100 dark:bg-gray-800 dark:text-gray-600 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed w-full sm:w-auto" disabled>&larr; Previous Post</button>
			{% else %}
			<a href="{{post.seq_id - 1}}" class="px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition w-full sm:w-auto text-center shadow-sm">&larr; Previous Post</a>
			{%endif%}
			
			<a href="/" class="px-6 py-3 text-sm font-medium text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-800/50 transition w-full sm:w-auto text-center shadow-sm">Home</a>
			
			{% if post.seq_id == max_post %}
			<button class="px-6 py-3 text-sm font-medium text-gray-400 bg-gray-100 dark:bg-gray-800 dark:text-gray-600 border border-gray-200 dark:border-gray-700 rounded-lg cursor-not-allowed w-full sm:w-auto" disabled>Next Post &rarr;</button>
			{%else%}
			<a href="{{post.seq_id + 1}}" class="px-6 py-3 text-sm font-medium text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition w-full sm:w-auto text-center shadow-sm">Next Post &rarr;</a>
			{%endif%}
		{%else%}
			<div class="w-full text-center">
				<a href="/" class="px-8 py-3 font-medium text-blue-700 dark:text-blue-300 bg-blue-50 dark:bg-blue-900/30 border border-blue-200 dark:border-blue-800 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-800/50 transition shadow-sm inline-block">Return to Home</a>
			</div>
		{%endif%}
	</nav>
</article>
{% endif %}

{% if flash %}
<div class="fixed bottom-4 right-4 bg-red-100 border-l-4 border-red-500 text-red-700 p-4 rounded shadow-lg transition-opacity duration-300" role="alert">
	<p class="font-bold">Notice</p>
	<p>{{ flash[1] }}</p>
</div>
{% endif %}
{% endblock %}