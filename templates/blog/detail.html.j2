{% extends "base" %}

{% macro render_comment_thread(thread, post_id, level) %}
<div class="mt-4" style="margin-left: {{ level * 1.5 }}rem;">
	<div class="glass-panel rounded-2xl p-5 border border-white/5 hover:border-white/10 transition-colors relative" data-comment-id="{{ thread.comment.id }}">
		{% if level > 0 %}
		<div class="absolute -left-[1.5rem] top-6 w-[1rem] border-t border-l border-white/10 h-8 rounded-tl-lg -z-10"></div>
		{% endif %}
		
		<div class="flex justify-between items-start mb-3">
			<div>
				<div class="font-bold text-white flex items-center gap-2 mb-1 text-sm">
					<div class="w-5 h-5 rounded-full bg-gradient-to-br from-purple-500 to-hypr-cyan flex items-center justify-center text-[10px] text-white">
						{{ thread.display_username[0] | upper }}
					</div>
					{{ thread.display_username }}
				</div>
				<div class="text-slate-300 text-sm leading-relaxed">{{ thread.comment.text }}</div>
			</div>
			<div class="flex flex-col items-end gap-2 shrink-0 ml-4">
				<div class="text-xs font-mono text-slate-500">{{ thread.comment.date_published }}</div>
				<button class="text-hypr-cyan hover:text-white font-mono text-xs uppercase tracking-widest transition-colors"
						hx-on:click="document.getElementById('reply-form-{{ thread.comment.id }}').style.display = 'block'">
					[ Reply ]
				</button>
			</div>
		</div>

		<!-- Reply form -->
		<div class="mt-4 pt-4 border-t border-white/5" id="reply-form-{{ thread.comment.id }}" style="display: none;">
			<form action="/comment/reply/{{ post_id }}/{{ thread.comment.id }}" method="post" class="flex flex-col gap-3 mx-auto max-w-2xl">
				{% if not token %}
				<div>
					<input type="text" id="username-{{ thread.comment.id }}" name="username" class="w-full px-4 py-2 bg-black/50 border border-white/10 rounded-lg text-white text-sm focus:outline-none focus:border-hypr-cyan transition-colors placeholder:text-slate-600" placeholder="Alias (optional)" />
				</div>
				{% endif %}
				<div>
					<textarea id="text-{{ thread.comment.id }}" name="text" class="w-full px-4 py-2 bg-black/50 border border-white/10 rounded-lg text-white text-sm focus:outline-none focus:border-hypr-cyan transition-colors placeholder:text-slate-600 resize-none" placeholder="Transmit reply..." required rows="2"></textarea>
				</div>
				<div class="flex gap-2 justify-end">
					<button class="px-4 py-1.5 rounded-lg bg-white/5 hover:bg-white/10 text-slate-300 text-xs font-medium transition-colors border border-transparent hover:border-white/10" type="button"
							hx-on:click="document.getElementById('reply-form-{{ thread.comment.id }}').style.display = 'none'; this.closest('form').reset()">Cancel</button>
					<button class="glow-btn px-4 py-1.5 rounded-lg bg-hypr-dark border border-hypr-cyan/50 text-white text-xs font-medium transition-transform hover:scale-105" type="submit">Submit</button>
				</div>
			</form>
		</div>
	</div>

	{% for reply in thread.replies %}
		{{ render_comment_thread(thread=reply, post_id=post_id, level=level + 1) }}
	{% endfor %}
</div>
{% endmacro %}

{% block content %}
{% if post %}
<article class="max-w-4xl mx-auto animate-fade-in-up">
	<header class="mb-16 text-center max-w-4xl mx-auto flex flex-col items-center">
		<h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white tracking-tight mb-6 leading-tight max-w-3xl" style="word-break: break-word;">
			{{post.title | safe}}
		</h1>
		
		{% if tags %}
		<div class="flex flex-wrap justify-center gap-2 mb-6">
			{% for tag in tags %}
			{% if loop.index0 < 3 %}
			<a href="/blog/tag/{{ tag.slug }}" class="text-xs font-mono px-3 py-1.5 rounded-full text-white border border-white/10 hover:border-white/30 transition-colors backdrop-blur-md" style="background-color: {{ tag.color }}20;">
				#{{ tag.name }}
			</a>
			{% endif %}
			{% endfor %}
			{% if tags|length > 3 %}
			<span class="text-xs font-mono px-3 py-1.5 rounded-full text-slate-400 bg-white/5 border border-white/10 backdrop-blur-md">
				+{{ tags|length - 3 }} more
			</span>
			{% endif %}
		</div>
		{% endif %}
		
		{% if post.draft and token %}
		<div class="inline-flex items-center gap-2 px-4 py-1.5 bg-amber-500/10 border border-amber-500/30 text-amber-400 rounded-full mb-6 font-mono text-sm tracking-widest uppercase">
			<span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
			Draft Mode
		</div>
		{% endif %}
		
		<div class="flex items-center justify-center gap-4 text-slate-400 font-mono text-sm">
			<div class="flex items-center gap-2">
				<span class="w-6 h-6 rounded-full bg-gradient-to-tr from-hypr-cyan to-purple-500 flex items-center justify-center text-white font-bold text-xs">
					{{ username[0] | upper if username else '?' }}
				</span>
				<span class="text-white font-medium">{{username}}</span>
			</div>
			<span class="text-slate-600">//</span>
			<time>{{post.date_published}}</time>
		</div>
		
		{%if is_admin %}
		<div class="mt-8 flex justify-center gap-3">
			{% if post.draft %}
			<a class="px-4 py-1.5 rounded-lg bg-hypr-teal/20 text-hypr-teal border border-hypr-teal/30 hover:bg-hypr-teal/30 transition-colors text-sm font-medium" href="{{post.seq_id}}/publish">Publish</a>
			{% endif %}
			<a class="px-4 py-1.5 rounded-lg bg-white/5 text-white border border-white/10 hover:bg-white/10 transition-colors text-sm font-medium" href="{{post.seq_id}}/edit">Edit</a>
			<a class="px-4 py-1.5 rounded-lg bg-red-500/10 text-red-400 border border-red-500/30 hover:bg-red-500/20 transition-colors text-sm font-medium" href="{{post.seq_id}}/delete">Delete</a>
		</div>
		{%endif%}
	</header>

	{%if post.path%}
	<div class="mb-16 rounded-3xl overflow-hidden glass-panel border border-white/10 shadow-[0_0_50px_rgba(0,168,244,0.1)] relative">
		<video class="w-full max-h-[70vh] object-contain bg-black" src="{{post.seq_id}}/video" controls autoplay></video>
		<div class="absolute inset-0 pointer-events-none rounded-3xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)]"></div>
	</div>
	{%endif%}

	<!-- Main Content -->
	<div class="glass-panel rounded-3xl p-8 md:p-12 border border-white/10 shadow-2xl mb-16 relative overflow-hidden">
		<!-- Subtle glow behind text -->
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-hypr-cyan/5 blur-[100px] pointer-events-none -z-10"></div>
		
		<div class="prose prose-invert prose-lg max-w-none markdown-body font-sans text-slate-300 leading-loose
			prose-headings:text-white prose-headings:font-bold prose-headings:tracking-tight
			prose-a:text-hypr-cyan prose-a:no-underline hover:prose-a:underline
			prose-pre:bg-black/60 prose-pre:border prose-pre:border-white/10 prose-pre:rounded-xl
			prose-code:text-hypr-teal prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md
			prose-img:rounded-2xl prose-img:border prose-img:border-white/10">
			{{post.text | safe}}
		</div>
	</div>

	<!-- Reactions -->
	<section class="mb-16">
		<div class="flex flex-wrap items-center gap-4 justify-center" data-post-id="{{post.seq_id}}">
			{% for reaction_type in reaction_types %}
			{% set is_active = reaction_summary.user_reaction == reaction_type.type %}
			<button class="group flex items-center gap-2 px-5 py-2.5 rounded-full border transition-all duration-300 
				{% if is_active %} bg-hypr-cyan/20 border-hypr-cyan text-white shadow-[0_0_15px_rgba(0,168,244,0.3)]
				{% else %} glass-panel border-white/10 text-slate-400 hover:bg-white/10 hover:border-white/20 hover:text-white{% endif %}"
					title="{{reaction_type.title}}"
					hx-post="{% if is_active %}/blog/{{post.seq_id}}/react{% else %}/blog/{{post.seq_id}}/react/{{reaction_type.type}}{% endif %}"
					hx-swap="none"
					hx-on::after-request="location.reload()">
				<span class="text-xl group-hover:scale-110 transition-transform">{{reaction_type.emoji}}</span>
				<span class="font-mono text-sm">
					{% set ns = namespace(count=0) %}
					{% for reaction in reaction_summary.reactions %}
						{% if reaction.reaction_type == reaction_type.type %}
							{% set ns.count = reaction.count %}
						{% endif %}
					{% endfor %}
					{{ ns.count }}
				</span>
			</button>
			{% endfor %}
		</div>
	</section>

	<!-- Comments -->
	<section class="mb-16 relative">
		<h3 class="text-2xl font-black text-white mb-8 tracking-tight flex items-center gap-3">
			<span class="text-hypr-cyan">#</span> Transmissions
		</h3>
		
		<div class="glass-panel rounded-3xl p-6 md:p-8 border border-white/10 mb-10 relative overflow-hidden">
			<div class="absolute top-0 right-0 w-32 h-32 bg-hypr-teal/10 blur-[50px] -z-10"></div>
			
			<form action="/comment/create/{{post.id}}" method="post" class="flex flex-col gap-4 relative z-10 max-w-3xl mx-auto">
				{% if not token %}
				<div>
					<input type="text" id="username" name="username" class="w-full px-5 py-3 bg-black/40 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-500" placeholder="Identify yourself (Alias)" />
				</div>
				{% endif %}
				<div>
					<textarea required id="text" name="text" class="w-full px-5 py-4 bg-black/40 border border-white/10 rounded-xl text-white focus:outline-none focus:border-hypr-cyan focus:ring-1 focus:ring-hypr-cyan transition-all placeholder:text-slate-500 min-h-[120px] resize-y" placeholder="Initiate transmission sequence..."></textarea>
				</div>
				<div class="flex justify-center mt-2">
					<button class="glow-btn px-8 py-3 rounded-full bg-hypr-dark border border-hypr-cyan/50 text-white font-medium transition-transform hover:scale-105" type="submit">Broadcast</button>
				</div>
			</form>
		</div>

		<div class="space-y-2">
			{% if comments %}
				{% for thread in comments %}
					{{ render_comment_thread(thread=thread, post_id=post.id, level=0) }}
				{% endfor %}
			{% else %}
				<div class="text-center py-12 text-slate-500 font-mono text-sm border border-dashed border-white/10 rounded-2xl glass-panel">
					No transmissions received yet.
				</div>
			{% endif %}
		</div>
	</section>

	<!-- Navigation -->
	<nav class="flex flex-col sm:flex-row items-center justify-between gap-4 py-8 border-t border-white/10">
		{%if token%}
			{% if post.seq_id == min_post %}
			<button class="px-6 py-3 text-sm font-medium text-slate-600 glass-panel rounded-xl border-white/5 cursor-not-allowed w-full sm:w-auto" disabled>&larr; Prev</button>
			{% else %}
			<a href="{{post.seq_id - 1}}" class="px-6 py-3 text-sm font-medium text-white glass-panel hover:bg-white/10 hover:border-white/20 transition-colors rounded-xl border border-white/10 w-full sm:w-auto text-center">&larr; Prev</a>
			{%endif%}
			
			<a href="/blog" class="px-6 py-3 text-sm font-mono tracking-widest uppercase text-hypr-cyan hover:text-white transition-colors w-full sm:w-auto text-center">Index</a>
			
			{% if post.seq_id == max_post %}
			<button class="px-6 py-3 text-sm font-medium text-slate-600 glass-panel rounded-xl border-white/5 cursor-not-allowed w-full sm:w-auto" disabled>Next &rarr;</button>
			{%else%}
			<a href="{{post.seq_id + 1}}" class="px-6 py-3 text-sm font-medium text-white glass-panel hover:bg-white/10 hover:border-white/20 transition-colors rounded-xl border border-white/10 w-full sm:w-auto text-center">Next &rarr;</a>
			{%endif%}
		{%else%}
			<div class="w-full text-center">
				<a href="/blog" class="px-8 py-3 text-sm font-mono tracking-widest uppercase text-hypr-cyan hover:text-white transition-colors inline-block border-b border-transparent hover:border-hypr-cyan">Return to Index</a>
			</div>
		{%endif%}
	</nav>
</article>
{% endif %}

{% if flash %}
<div class="fixed bottom-6 right-6 p-4 rounded-xl glass-panel border border-red-500/50 text-white shadow-[0_0_30px_rgba(239,68,68,0.2)] z-50 animate-fade-in-up">
	<p class="font-mono text-sm text-red-400 mb-1">// SYSTEM NOTICE</p>
	<p>{{ flash[1] }}</p>
</div>
{% endif %}
{% endblock %}