{% extends "base" %}

{% block content %}
<div class="terminal-header"></div>
<center>
	<h1 class="terminal-cursor">Settings</h1>
	<p class="text-muted">Manage your blog configuration</p>
</center>

<hr class="terminal-divider">

<div class="container">
	<!-- OpenAI Configuration Section -->
	<div class="row justify-content-center">
		<div class="col-md-8">
			<div class="card terminal-card mb-4">
				<div class="card-header">
					<h3 class="mb-0">🤖 OpenAI Integration</h3>
				</div>
				<div class="card-body">
					<p class="card-text">
						Configure OpenAI API key to enable AI-powered blog post generation features.
						{% if openai_configured %}
						<span class="badge bg-success ms-2">✓ Configured</span>
						{% else %}
						<span class="badge bg-warning ms-2">⚠ Not Configured</span>
						{% endif %}
					</p>
					
					{% if openai_configured %}
					<div class="alert alert-info">
						<strong>✓ OpenAI is configured!</strong> AI generation features are available in the blog editor.
					</div>
					
					<div class="row">
						<div class="col-md-6">
							<form action="/settings/openai" method="post" class="mb-3">
								<label for="openai_api_key" class="form-label">Update API Key:</label>
								<input type="password" name="openai_api_key" id="openai_api_key" class="form-control" placeholder="sk-..." required />
								<div class="form-text">Enter a new OpenAI API key to replace the current one</div>
								<button type="submit" class="btn btn-primary mt-2">[UPDATE API KEY]</button>
							</form>
						</div>
						<div class="col-md-6">
							<form action="/settings/openai" method="post" onsubmit="return confirm('Are you sure you want to remove the OpenAI API key? This will disable AI features.');">
								<input type="hidden" name="_method" value="delete" />
								<label class="form-label">Remove Configuration:</label>
								<div>
									<button type="submit" class="btn btn-danger">[REMOVE API KEY]</button>
								</div>
								<div class="form-text">This will disable all AI generation features</div>
							</form>
						</div>
					</div>
					{% else %}
					<div class="alert alert-warning">
						<strong>⚠ OpenAI not configured!</strong> AI generation features will not be available until you configure an API key.
					</div>
					
					<form action="/settings/openai" method="post">
						<div class="mb-3">
							<label for="openai_api_key" class="form-label">OpenAI API Key:</label>
							<input type="password" name="openai_api_key" id="openai_api_key" class="form-control" placeholder="sk-proj-..." required />
							<div class="form-text">
								Enter your OpenAI API key. Get one from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a>
							</div>
						</div>
						<button type="submit" class="btn btn-success">[SAVE API KEY]</button>
					</form>
					{% endif %}
					
					<div class="mt-4">
						<h5>Features enabled with OpenAI:</h5>
						<ul class="list-unstyled">
							<li>✨ Auto-generate blog post content from titles</li>
							<li>✨ Generate engaging excerpts from existing content</li>
							<li>✨ Suggest relevant tags based on content</li>
						</ul>
						
						<h6>Cost Information:</h6>
						<small class="text-muted">
							Estimated costs using GPT-3.5-turbo: Content generation ~$0.003 per post, 
							Excerpt generation ~$0.0003 per post, Tag generation ~$0.0002 per post
						</small>
					</div>
				</div>
			</div>
		</div>
	</div>
	
	<!-- Ollama Configuration Section -->
	<div class="row justify-content-center">
		<div class="col-md-8">
			<div class="card terminal-card mb-4">
				<div class="card-header">
					<h3 class="mb-0">🦙 Ollama Integration</h3>
				</div>
				<div class="card-body">
					<p class="card-text">
						Configure Ollama for self-hosted AI-powered blog post generation features.
						{% if ollama_enabled %}
						<span class="badge bg-success ms-2">✓ Enabled</span>
						{% else %}
						<span class="badge bg-warning ms-2">⚠ Disabled</span>
						{% endif %}
					</p>
					
					<div class="alert alert-info">
						<strong>ℹ️ About Ollama:</strong> Ollama is a self-hosted AI solution that runs locally on your machine. 
						No API keys required, and your data stays private.
					</div>
					
					<form action="/settings/ollama" method="post">
						<div class="row">
							<div class="col-md-6">
								<div class="mb-3">
									<label for="ollama_url" class="form-label">Ollama URL:</label>
									<input type="url" name="ollama_url" id="ollama_url" class="form-control" 
										   value="{{ ollama_url | default(value='http://localhost:11434') }}" 
										   placeholder="http://localhost:11434" required />
									<div class="form-text">URL where your Ollama server is running</div>
								</div>
							</div>
							<div class="col-md-6">
								<div class="mb-3">
									<label for="ollama_model" class="form-label">Model:</label>
									<input type="text" name="ollama_model" id="ollama_model" class="form-control" 
										   value="{{ ollama_model | default(value='llama2') }}" 
										   placeholder="llama2" required />
									<div class="form-text">Model name to use (e.g., llama2, mistral, codellama)</div>
								</div>
							</div>
						</div>
						
						<div class="mb-3">
							<div class="form-check">
								<input type="checkbox" name="ollama_enabled" id="ollama_enabled" class="form-check-input" 
									   value="true" {% if ollama_enabled %}checked{% endif %} />
								<label for="ollama_enabled" class="form-check-label">Enable Ollama Integration</label>
								<div class="form-text">When enabled, Ollama will be used for AI features</div>
							</div>
						</div>
						
						<div class="row">
							<div class="col-md-6">
								<button type="submit" class="btn btn-success">[SAVE OLLAMA SETTINGS]</button>
							</div>
						</div>
					</form>
					
					<div class="row">
						<div class="col-md-6 offset-md-6">
							<form action="/settings/ollama" method="post" onsubmit="return confirm('Are you sure you want to remove all Ollama settings?');">
								<input type="hidden" name="_method" value="delete" />
								<button type="submit" class="btn btn-danger">[REMOVE OLLAMA SETTINGS]</button>
							</form>
						</div>
					</div>
					
					<div class="mt-4">
						<h5>Features enabled with Ollama:</h5>
						<ul class="list-unstyled">
							<li>🏠 Self-hosted AI processing (no external API calls)</li>
							<li>🔒 Complete data privacy (everything runs locally)</li>
							<li>✨ Auto-generate blog post content from titles</li>
							<li>✨ Generate engaging excerpts from existing content</li>
							<li>✨ Suggest relevant tags based on content</li>
						</ul>
						
						<h6>Setup Requirements:</h6>
						<small class="text-muted">
							1. Install Ollama from <a href="https://ollama.ai/" target="_blank">ollama.ai</a><br>
							2. Download a model: <code>ollama pull llama2</code><br>
							3. Start Ollama: <code>ollama serve</code><br>
							4. Configure settings above and enable integration
						</small>
					</div>
				</div>
			</div>
		</div>
	</div>
	
	<!-- Navigation -->
	<div class="text-center mt-4">
		<a href="/blog" class="btn btn-secondary">[← BACK TO BLOG]</a>
	</div>
</div>

{% if flash %}
<div class="alert alert-{{ flash[0] }} text-center mt-3">
	{{ flash[1] }}
</div>
{% endif %}

{% endblock %}

{% block script %}
<script>
document.addEventListener('DOMContentLoaded', function() {
	// Handle DELETE method for removing OpenAI API key
	const openaiDeleteForms = document.querySelectorAll('form[action="/settings/openai"] input[name="_method"][value="delete"]');
	openaiDeleteForms.forEach(function(input) {
		const form = input.closest('form');
		form.addEventListener('submit', function(e) {
			e.preventDefault();
			
			if (confirm('Are you sure you want to remove the OpenAI API key? This will disable AI features.')) {
				// Create a proper DELETE request
				fetch('/settings/openai', {
					method: 'DELETE',
					headers: {
						'Content-Type': 'application/x-www-form-urlencoded',
					}
				}).then(function(response) {
					window.location.reload();
				}).catch(function(error) {
					alert('Error removing API key: ' + error.message);
				});
			}
		});
	});
	
	// Handle DELETE method for removing Ollama settings
	const ollamaDeleteForms = document.querySelectorAll('form[action="/settings/ollama"] input[name="_method"][value="delete"]');
	ollamaDeleteForms.forEach(function(input) {
		const form = input.closest('form');
		form.addEventListener('submit', function(e) {
			e.preventDefault();
			
			if (confirm('Are you sure you want to remove all Ollama settings? This will disable Ollama integration.')) {
				// Create a proper DELETE request
				fetch('/settings/ollama', {
					method: 'DELETE',
					headers: {
						'Content-Type': 'application/x-www-form-urlencoded',
					}
				}).then(function(response) {
					window.location.reload();
				}).catch(function(error) {
					alert('Error removing Ollama settings: ' + error.message);
				});
			}
		});
	});
});
</script>
{% endblock %}