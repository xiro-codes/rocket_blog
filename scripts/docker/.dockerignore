# Ignore git and documentation
.git
.gitignore
*.md
README.*

# Ignore build artifacts - we'll build inside container
target/
# Keep Cargo.lock - needed for reproducible builds

# Ignore IDE/editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore temporary files
.tmp/
tmp/
temp/

# Ignore environment files (except those needed for Docker)
.env
.env.example
.envrc

# Ignore Docker files not needed in container
.Dockerfile
docker-compose*
.dockerignore

# Ignore scripts and nix files not needed in container
scripts/
justfile
flake.*
output.log

# Ignore development database data
*.db
*.sqlite