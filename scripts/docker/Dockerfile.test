# Docker image for running tests in Rocket Blog dual-binary architecture
# This Dockerfile creates a containerized test environment for both binaries

FROM rust:1.89-bookworm

# Install build dependencies (same as main Dockerfile for consistency)
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    ca-certificates \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install yt-dlp for testing youtube download functionality
RUN pip3 install --no-cache-dir --break-system-packages yt-dlp

# Set working directory
WORKDIR /app

# Copy dependency files first for better Docker layer caching
COPY Cargo.toml Cargo.lock ./
COPY migrations ./migrations/
COPY models ./models/

# Copy source code
COPY src ./src/

# Copy templates and static files for integration tests
COPY templates ./templates/
COPY static ./static/

# Run tests for both binaries (no pre-build step to avoid issues)
CMD ["cargo", "test", "--bins", "--", "--nocapture"]