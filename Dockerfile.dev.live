# Live Development Dockerfile for Rocket Blog
# Includes cargo-watch for automatic rebuilds on code changes

FROM rust:1.89-bookworm

# Install build and runtime dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Pre-install cargo-watch for live reloading
# This is installed in a separate layer to avoid network issues during builds
RUN cargo install cargo-watch || echo "cargo-watch installation failed, will install at runtime"

# Create app user
RUN useradd -m -u 1000 app

# Set working directory
WORKDIR /app

# Copy static assets and templates
COPY templates ./templates/
COPY static ./static/
COPY .Rocket.docker.toml ./Rocket.toml

# Copy project files
COPY Cargo.toml Cargo.lock ./
COPY migrations ./migrations/
COPY models ./models/
COPY src ./src/

# Create data directory for file uploads
RUN mkdir -p /app/data && chown -R app:app /app

# Change to app user
USER app

# Expose port
EXPOSE 8000

# Install cargo-watch if not already installed
RUN cargo install cargo-watch || echo "cargo-watch already installed or failed to install"

# Use cargo-watch for live development
CMD ["sh", "-c", "cargo watch -x run || cargo run"]