# Rocket Blog Environment Configuration
# Copy this file to .env and modify values as needed

# Database Configuration
DATABASE_URL=postgres://master:password@localhost/tdavis_dev

# Application Configuration  
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8000
ROCKET_DATA_PATH=/home/user/.local/share/blog

# Security Configuration
# Generate a secure secret key with: openssl rand -base64 32
ROCKET_SECRET_KEY=your-32-character-base64-secret-key-here

# Development vs Production Environment
ROCKET_ENV=development
# Set to 'release' for production deployment

# File Upload Limits
ROCKET_LIMITS_FILE=1073741824    # 1GB in bytes
ROCKET_LIMITS_FORM=1073741824    # 1GB in bytes
ROCKET_LIMITS_DATA_FORM=1073741824    # 1GB in bytes

# Logging Configuration (Optional)
RUST_LOG=info
RUST_BACKTRACE=1

# PostgreSQL Specific Settings (Optional)
PGUSER=master
PGPASSWORD=password
PGDATABASE=tdavis_dev
PGHOST=localhost
PGPORT=5432

# Development Features (Optional)
# Set to false in production
ENABLE_SEEDING=true
SEEDING_POST_COUNT=50

# Production Security Settings (Production Only)
# ROCKET_TLS_CERTS=/path/to/cert.pem
# ROCKET_TLS_KEY=/path/to/key.pem

# Backup Configuration (Production Only)  
# BACKUP_DIRECTORY=/backups/rocket-blog
# BACKUP_RETENTION_DAYS=30

# Email Configuration (Future Feature)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-email-password
# FROM_EMAIL=noreply@your-domain.com

# CDN Configuration (Future Feature)
# CDN_URL=https://cdn.your-domain.com
# STATIC_ASSETS_URL=https://cdn.your-domain.com/static

# Analytics Configuration (Future Feature)  
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# ENABLE_ANALYTICS=true

# Social Media Integration (Future Feature)
# SOCIAL_TWITTER_URL=https://twitter.com/your-handle
# SOCIAL_GITHUB_URL=https://github.com/your-username
# SOCIAL_LINKEDIN_URL=https://linkedin.com/in/your-profile